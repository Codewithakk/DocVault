<%- include('../../partials/header') %>

<div class="page-wrapper">
    <div class="content">
        <!-- Breadcrumb -->
        <div class="dflexbtwn page-breadcrumb mb-3">
            <div class="my-auto mb-2">
                <h2 class="mb-1">
                    <%= title %>
                </h2>
                <nav>
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#"><i class="ti ti-smart-home"></i></a></li>
                        <li class="breadcrumb-item active">Designation List</li>
                    </ol>
                </nav>
            </div>
            <div>
                <a href="/designations" class="btn btn-primary">
                    <i class="ti ti-plus me-1"></i> Add Designation
                </a>
            </div>
        </div>

        <!-- Designation Table -->
        <div class="card">
            <div class="card-body p-0">
                <div class="custom-datatable-filter table-responsive">
                    <table class="table datatable" id="designationTable">
                        <thead class="thead-light">
                            <tr>
                                <th>Sr No.</th>
                                <th>Action</th>
                                <th>Name</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Permissions</th>
                                <th>Added By</th>
                                <th>Updated By</th>
                                <th>Created At</th>
                            </tr>
                        </thead>
                        <tbody id="designationTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer mt-4 d-sm-flex align-items-center justify-content-between border-top bg-white p-3">
            <p class="mb-0">2025 &copy; HLFPPT.</p>
            <p>Designed & Developed by <a href="javascript:void(0);" id="devLink" class="text-primary">Duplex
                    Services & Technology</a></p>
        </div>
    </div>
</div>

<%- include('../../modals/deleteModal') %>
<%- include('../../partials/footer') %>

<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<script>
  $(document).ready(function () {
    let deleteDesigId = null;
    let dataTable = null;

    // Fetch designations via API
    $.ajax({
        url: `${baseUrl}/api/designations`,
        method: 'GET',
        success: function (res) {
            if (!res.success) return showToast('Failed to fetch designations', 'error');

            let tbody = '';
            res.data.forEach((desig, index) => {
                let addedBy = desig.added_by?.email || '-';
                let updatedBy = desig.updated_by?.email || '-';
                let createdAt = formatDateTime(desig.add_date);
                // Build permissions string
                let permissions = [];
                if (desig.allOrgs) permissions.push('All Orgs');
                if (desig.deptFiles) permissions.push('Dept Files');
                if (desig.otherDepts) permissions.push('Other Depts');
                if (desig.ownFiles) permissions.push('Own Files');
                if (desig.ownFolders) permissions.push('Own Folders');
                if (desig.teamFiles) permissions.push('Team Files');
                
                let permissionDisplay = permissions.length > 0 ? permissions.join(', ') : '—';
                
                tbody += `
                    <tr>
                        <td>${index + 1}</td>
                        <td>
                            <a href="/designations/edit/${desig._id}" class="text-primary me-2" title="Edit"><i class="ti ti-edit"></i></a>
                            <a href="#" class="text-danger btn-delete" data-id="${desig._id}" title="Delete"><i class="ti ti-trash"></i></a>
                        </td>
                        <td>${desig.name}</td>
                        <td>${desig.priority}</td>
                        <td><span class="badge ${desig.status === 'Active' ? 'bg-success' : 'bg-secondary'}">${desig.status}</span></td>
                        <td>${permissionDisplay}</td>
                        <td>${addedBy}</td>
                        <td>${updatedBy}</td>
                        <td>${createdAt}</td>
                    </tr>
                `;
            });
            $('#designationTableBody').html(tbody);

            // Destroy existing DataTable instance if it exists
            if ($.fn.DataTable.isDataTable('#designationTable')) {
                $('#designationTable').DataTable().destroy();
            }

            // Initialize DataTable
            dataTable = $('#designationTable').DataTable({
                "columnDefs": [
                    { "orderable": false, "targets": [0, 1] },
                    { "orderable": true, "targets": [2, 3, 4, 5, 6, 7, 8] }
                ],
                "order": [],
                "pageLength": 10,
                "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]]
            });
        },
        error: function (err) { 
            console.error(err);
            showToast('Failed to load designations', 'error');
        }
    });

    // Delete designation
    $(document).on('click', '.btn-delete', function (e) {
        e.preventDefault();
        deleteDesigId = $(this).data('id');
        $('#confirmDeleteModal').modal('show');
    });

    $('#confirmDeleteBtn').click(function () {
        if (!deleteDesigId) return;

        $.ajax({
            url: `${baseUrl}/api/designations/${deleteDesigId}`,
            method: 'DELETE',
            success: function (res) {
                $('#confirmDeleteModal').modal('hide');
                if (res.success) {
                    showToast(res.message || 'Designation deleted successfully!', 'success');
                    // Refresh the table instead of page reload
                    setTimeout(() => { window.location.href = '/designations/list'; }, 1000);
                } else {
                    showToast(res.message || 'Failed to delete designation', 'danger');
                }
            },
            error: function (err) {
                $('#confirmDeleteModal').modal('hide');
                let msg = err.responseJSON?.message || 'Something went wrong';
                showToast(msg, 'warning');
            }
        });
    });
});
</script>