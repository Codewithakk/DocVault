<%- include('../../partials/header') %>

    <div class="page-wrapper">
        <div class="content">

            <!-- Breadcrumb -->
            <div class="d-md-flex d-block align-items-center justify-content-between page-breadcrumb mb-3">
                <div class="my-auto mb-2">
                    <h2 class="mb-1">
                        <%= designation ? 'Edit' : 'Add' %> Designation
                    </h2>
                    <nav>
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item">
                                <a href="#"><i class="ti ti-smart-home"></i></a>
                            </li>
                            <li class="breadcrumb-item active">
                                <%= designation ? 'Edit' : 'Add' %> Designation
                            </li>
                        </ol>
                    </nav>
                </div>
                <div>
                    <a class="btn btn-primary btn-w-lg rounded-pill" href="/designations/list">List</a>
                </div>
            </div>

            <!-- Toast container -->
            <div id="toastContainer" style="position: fixed; top: 20px; right: 20px; z-index: 9999;"></div>

            <!-- Form -->
            <div class="add-info-fieldset">
                <form id="designationForm" novalidate>
                    <div class="row">

                        <!-- Name -->
                        <div class="col-md-6 mb-3">
                            <label for="name" class="form-label">Designation Name <span class="text-danger">*</span></label>
                            <input type="text" id="name" name="name" class="form-control"
                                placeholder="Enter designation name" value="<%= designation ? designation.name : '' %>"
                                required>
                        </div>

                        <!-- Priority -->
                        <div class="col-md-3 mb-3">
                            <label for="priority" class="form-label">Priority</label>
                            <input type="number" id="priority" name="priority" class="form-control"
                                placeholder="Enter priority" min="0"
                                value="<%= designation ? designation.priority : '' %>">
                        </div>

                        <!-- Status -->
                        <div class="col-md-3 mb-3">
                            <label for="status" class="form-label">Status</label>
                            <select id="status" name="status" class="form-select select2">
                                <option value="Active" <%=designation && designation.status==='Active' ? 'selected' : '' %>>Active</option>
                                <option value="Inactive" <%=designation && designation.status==='Inactive' ? 'selected' : '' %>>Inactive</option>
                            </select>
                        </div>

                        <!-- Is Donor or Vendor -->
                        <div class="col-md-4 mb-1 mt-2">
                            <div class="form-check">
                                <input type="checkbox" id="isDonorOrVendor" name="isDonorOrVendor" class="form-check-input" 
                                    value="true" <%=designation && designation.isDonorOrVendor ? 'checked' : '' %> >
                                <label class="form-check-label" for="isDonorOrVendor">Is Donor / Vendor?</label>
                            </div>
                        </div>
                        <!-- Permissions Section Header -->
                        <div class="col-12 mt-2 mb-1">
                            <hr>
                            <h5 class="mb-0">Permissions</h5>
                            <small class="text-muted">Select the permissions for this designation</small>
                            <hr>
                        </div>


                        <!-- Own Files -->
                        <div class="col-md-4 mb-3">
                            <div class="form-check">
                                <input type="checkbox" id="ownFiles" name="ownFiles" class="form-check-input" 
                                    value="true" <%=designation && designation.ownFiles ? 'checked' : '' %> >
                                <label class="form-check-label" for="ownFiles">Own Files</label>
                            </div>
                        </div>

                        <!-- Own Folders -->
                        <div class="col-md-4 mb-3">
                            <div class="form-check">
                                <input type="checkbox" id="ownFolders" name="ownFolders" class="form-check-input" 
                                    value="true" <%=designation && designation.ownFolders ? 'checked' : '' %> >
                                <label class="form-check-label" for="ownFolders">Own Folders</label>
                            </div>
                        </div>

                        <!-- Team Files -->
                        <div class="col-md-4 mb-3">
                            <div class="form-check">
                                <input type="checkbox" id="teamFiles" name="teamFiles" class="form-check-input" 
                                    value="true" <%=designation && designation.teamFiles ? 'checked' : '' %> >
                                <label class="form-check-label" for="teamFiles">Team Files</label>
                            </div>
                        </div>

                        <!-- Department Files -->
                        <div class="col-md-4 mb-3">
                            <div class="form-check">
                                <input type="checkbox" id="deptFiles" name="deptFiles" class="form-check-input" 
                                    value="true" <%=designation && designation.deptFiles ? 'checked' : '' %> >
                                <label class="form-check-label" for="deptFiles">Department Files</label>
                            </div>
                        </div>

                        <!-- Other Departments -->
                        <div class="col-md-4 mb-3">
                            <div class="form-check">
                                <input type="checkbox" id="otherDepts" name="otherDepts" class="form-check-input" 
                                    value="true" <%=designation && designation.otherDepts ? 'checked' : '' %> >
                                <label class="form-check-label" for="otherDepts">Other Departments</label>
                            </div>
                        </div>

                        <!-- All Organizations -->
                        <div class="col-md-4 mb-3">
                            <div class="form-check">
                                <input type="checkbox" id="allOrgs" name="allOrgs" class="form-check-input" 
                                    value="true" <%=designation && designation.allOrgs ? 'checked' : '' %> >
                                <label class="form-check-label" for="allOrgs">All Organizations</label>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="col-12 mb-3 mt-4">
                            <label for="description" class="form-label">
                                Description <span class="text-muted">(Optional)</span>
                            </label>
                            <textarea id="description" name="description" rows="3" class="form-control"
                                placeholder="Enter description"><%= designation ? designation.description : '' %></textarea>
                        </div>

                    </div>

                    <!-- Submit -->
                    <div class="d-flex align-items-center justify-content-end mt-4">
                        <button id="submitBtn" class="btn btn-primary btn-w-lg rounded-pill" type="submit">
                            <%= designation ? 'Update' : 'Add' %>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer mt-4 d-sm-flex align-items-center justify-content-between border-top bg-white p-3">
            <p class="mb-0">2025 &copy; HLFPPT.</p>
            <p>
                Designed & Developed by
                <a href="https://duplexservices.com" target="_blank" class="text-primary">Duplex Services & Technology</a>
            </p>
        </div>
    </div>

    <%- include('../../partials/footer') %>

    <script>
        const form = document.getElementById('designationForm');
        const submitBtn = document.getElementById('submitBtn');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const originalBtnText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = `
                <span class="spinner-border spinner-border-sm me-2"></span> Processing...
            `;

            // Collect form data
            const formData = new FormData(form);
            
            // Get all checkbox fields and convert to proper boolean values
            const checkboxFields = ['isDonorOrVendor', 'ownFiles', 'ownFolders', 'teamFiles', 'deptFiles', 'otherDepts', 'allOrgs'];
            
            // Create data object
            const data = {};
            
            // Handle regular form fields
            for (let [key, value] of formData.entries()) {
                // Skip checkbox fields - we'll handle them separately
                if (!checkboxFields.includes(key)) {
                    data[key] = value;
                }
            }
            
            // Handle checkbox fields - convert to proper boolean
            checkboxFields.forEach(field => {
                const checkbox = document.getElementById(field);
                data[field] = checkbox ? checkbox.checked : false;
            });

            const id = "<%= designation ? designation._id : '' %>";
            const url = id ? `/api/designations/${id}` : '/api/designations';
            const method = id ? 'PATCH' : 'POST';

            try {
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await res.json();

                if (res.ok) {
                    showToast(result.message || 'Saved successfully!', 'success');
                    setTimeout(() => window.location.href = '/designations/list', 1000);
                } else {
                    // Handle validation errors
                    if (result.errors && Array.isArray(result.errors)) {
                        const errorMessages = result.errors.map(err => err.message || err.msg).join(', ');
                        showToast(errorMessages || 'Validation failed', 'danger');
                    } else {
                        showToast(result.message || 'Failed to save.', 'danger');
                    }
                }
            } catch (err) {
                showToast('Something went wrong!', 'danger');
                console.error('Error:', err);
            } finally {
                submitBtn.innerHTML = originalBtnText;
                submitBtn.disabled = false;
            }
        });

        // Toast notification function
        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `alert alert-${type} alert-dismissible fade show`;
            toast.role = 'alert';
            toast.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            container.appendChild(toast);
            
            // Auto dismiss after 5 seconds
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.remove();
                }
            }, 5000);
        }
    </script>