<%- include('../../partials/header') %>
<!-- Page Wrapper -->
<div class="page-wrapper">
    <div class="content">

        <!-- Breadcrumb -->
        <div class="d-md-flex d-block align-items-center justify-content-between page-breadcrumb mb-3">
            <div class="my-auto mb-2">
                <h2 class="mb-1">
                    <%= isEdit ? "Edit Document" : "Add Document" %>
                </h2>
                <nav>
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#"><i class="ti ti-smart-home"></i></a></li>
                        <li class="breadcrumb-item">
                            <%= isEdit ? "Edit Document" : "Add Document" %>
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
        <!-- /Breadcrumb -->

        <div class="add-info-fieldset">
            <form id="documentForm" enctype="multipart/form-data">
                <% if (isEdit) { %>
                    <input type="hidden" name="_method" value="PATCH">
                <% } %>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-8">
                            <div class="card">
                                <div class="card-body row">
                                    <!-- File Upload -->
                                    <div class="col-md-6">
                                        <label class="form-label">File Uploads</label>
                                        <div class="upload-box mb-3" id="uploadBox">
                                            <i class="ti ti-cloud-upload fa-2x text-primary mb-2"></i>
                                            <p class="mb-1"><strong>Click to upload file</strong> or drag and drop</p>
                                            <small class="text-muted">Max 10GB total storage. DOCX / PPTX / CSV / PDF</small>
                                            <input type="file" class="form-control d-none" id="fileInput" name="files" multiple>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div id="fileList">
                                            <label class="form-label">Selected Files</label>
                                            <!-- existing file list code -->
                                        </div>
                                    </div>                                                
                                </div>
                            </div>

                            <div class="card">
                                <div class="card-header border-0 pb-0">
                                    <h6 class="d-flex align-items-center"> <i class="ti ti-notes fs-22 text-primary me-1"></i> Document Information</h6>
                                </div>
                                <div class="card-body row">
                                    <!-- Project Name -->
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label class="form-label">Project Name</label>
                                            <select id="projectName" name="project" class="form-select select2" required>
                                                <% if (!isEdit && selectedProject) { %>
                                                    <option value="<%= selectedProject._id %>" selected>
                                                        <%= selectedProject.projectName %>
                                                    </option>
                                                <% } %>
                                                <% if (isEdit && document.project) { %>
                                                    <option value="<%= document.project._id %>" selected>
                                                        <%= document.project.projectName %>
                                                    </option>
                                                <% } %>
                                            </select>
                                        </div>
                                    </div>

                                    <!-- Department -->
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label class="form-label">Department </label>
                                            <select id="department" name="department" class="form-select select2" required>
                                            </select>
                                        </div>
                                    </div>

                                    <!-- Donor Name -->
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label class="form-label">Donor Name</label>
                                            <select id="documentDonor" name="documentDonor" class="form-select select2">
                                                <option value="">-- Select Donor Name --</option>
                                            </select>
                                        </div>
                                    </div>

                                    <!-- Vendor Name -->
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label class="form-label">Vendor Name</label>
                                            <select id="documentVendor" name="documentVendor" class="form-select select2">
                                                <option value="">-- Select Vendor Name --</option>
                                            </select>
                                        </div>
                                    </div>
                                    
                                    <!-- Metadata -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label class="form-label">Meta Data - File Name</label>
                                            <input class="form-control" type="text" name="metadata[fileName]" placeholder="File Name" value="<%= isEdit && document.metadata && document.metadata.fileName ? document.metadata.fileName : '' %>">
                                        </div>
                                    </div>
                                    
                                    <!-- Tags -->
                                    <div class="col-md-8">
                                        <div class="mb-3">
                                            <label class="form-label">Add Tags</label>
                                            <input type="text" name="tags" class="form-control" placeholder="tag1, tag2, tag3" value="<%= isEdit && document.tags ? document.tags.join(', ') : '' %>">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="card">
                                <div class="card-header border-0 pb-0">
                                    <h6 class="d-flex align-items-center"> <i class="ti ti-edit fs-22 text-primary me-1"></i> Description</h6>
                                </div>
                                <div class="card-body row">
                                    <div class="col-md-12">
                                        <div class="mb-3">
                                            <textarea id="summernote" name="description" style="display: none;"><%= isEdit && document.description ? document.description : '' %></textarea>
                                            <div class="summernote">
                                                <%- isEdit && document.description ? document.description : '' %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-8">
                                    <div class="card">
                                        <div class="card-header border-0 pb-0">
                                            <h6 class="d-flex align-items-center"> <i class="ti ti-folder-open fs-22 text-primary me-1"></i> Organization</h6>
                                            <button type="button" 
                                            id="createFolderBtn" 
                                            class="btn btn-sm btn-primary rounded-pill" 
                                            disabled 
                                            style="opacity: 0.5; cursor: not-allowed;"
                                            title="Please select both Project and Department">
                                        <i class="ti ti-plus me-1"></i> Add Folder
                                    </button>
                                        </div>
                                        <div class="card-body">
                                            <div class="d-flex gap-4">
                                                <p class="card-header-org-title">Folder Path</p>
                                                <div class="breadcrumb-nav" id="dynamicBreadcrumb">
                                                    <i class="ti ti-folder" style="color: var(--primary-blue); font-size: 1rem; padding-right: 1px;"></i>
                                                    <span class="text-muted">Select a folder</span>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-3">
                                                <div class="card-body-org" style="flex: 1;">
                                                    <ul class="folder-tree" id="dynamicFolderTree">
                                                        <div id="folderTreeLoader" class="text-center py-3 d-none">
                                                            <div class="spinner-border text-primary" role="status">
                                                                <span class="visually-hidden">Loading folders...</span>
                                                            </div>
                                                        </div>
                                                    </ul>
                                                </div>
                                                <div class="folder-grid-container" style="flex: 1;">
                                                    <div class="grid-header">
                                                        <h3 class="grid-title">Frequently Used</h3>
                                                    </div>
                                                    <div class="folder-grid" id="dynamicFolderGrid">
                                                        <div id="folderGridLoader" class="text-center py-3 d-none">
                                                            <div class="spinner-border text-primary" role="status">
                                                                <span class="visually-hidden">Loading...</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <input type="hidden" name="folderId" id="selectedFolderId">
                                        </div>
                                    </div>                                             
                                </div>
                                <div class="col-md-4">
                                    <div class="card">
                                        <div class="card-header border-0 pb-0">
                                            <h6 class="d-flex align-items-center"> <i class="ti ti-shield-check fs-22 text-primary me-1"></i> Options</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <div class="d-flex align-items-center gap-5">
                                                    <label class="form-label mb-0">Compliance and Retention Document</label>
                                                    <div class="form-switch ps-2">
                                                        <input class="form-check-input" type="checkbox" id="complianceSwitch" name="compliance" value="yes" <%= isEdit && document.compliance?.isCompliance ? 'checked' : '' %>>
                                                    </div>
                                                </div>
                                            </div>
                                        
                                            <div class="mb-3" id="expiryDateContainer" style="display: <%= isEdit && document.compliance?.isCompliance ? 'block' : 'none' %>;">
                                                <div class="d-flex align-items-center gap-5">
                                                    <label class="form-label mb-0">Enter Expiry Date</label>
                                                    <div class="input-icon-end position-relative">
                                                        <input type="text" class="form-control datetimepicker" name="expiryDate" placeholder="dd/mm/yyyy" value="<%= isEdit && document.compliance?.expiryDate ? new Date(document.compliance.expiryDate).toLocaleDateString('en-GB') : '' %>" <%=isEdit && document.compliance?.isCompliance ? 'required' : '' %>>
                                                        <span class="input-icon-addon"><i class="ti ti-calendar text-gray-7"></i></span>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="mb-3">
                                                <div class="d-flex align-items-center gap-5">
                                                    <label class="form-label mb-0">File Access grant Required</label>
                                                    <div class="form-switch ps-2">
                                                        <input class="form-check-input" type="checkbox" id="wantApprovers" name="wantApprovers" value="no" <%= isEdit && document.wantApprovers?.iswantApprovers ? 'checked' : '' %>>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label">Comment (Optional)</label>
                                                <textarea class="form-control" rows="3" placeholder="Add any additional comments..." name="comment" value="<%= isEdit && document.comment ? document.comment : '' %>"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="card">
                                <div class="card-header border-0 pb-0">
                                    <h6 class="d-flex align-items-center"><i class="ti ti-file-database fs-22 text-primary me-1"></i> Metadata</h6>
                                </div>
                                <div class="card-body">
                                    <div class="col-md-12" id="metadataDisplay">
                                        <!-- ALL uploaded files metadata will be populated dynamically -->
                                        <p class="text-muted">No files uploaded yet</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="sideupldwrp card">
                                <div class="card-header">
                                    <h6 class="d-flex align-items-center"><i class="ti ti-notes fs-22 text-primary me-1"></i> Upload Summary</h6>
                                </div>
                                <div class="sideupldtxt card-body" id="uploadSummary">
                                    <div class="mb-4">
                                        <p class="fs-14 fw-medium text-gray mb-2">Project</p>
                                        <span class="fs-14 text-dark" id="summaryProject">--</span>
                                    </div>
                                    <div class="mb-4">
                                        <p class="fs-14 fw-medium text-gray mb-2">Department</p>
                                        <span class="fs-14 text-dark" id="summaryDepartment">--</span>
                                    </div>
                                    <div class="mb-4">
                                        <p class="fs-14 fw-medium text-gray mb-2">Folder</p>
                                        <span class="fs-14 text-dark" id="summaryFolder">--</span>
                                    </div>
                                    <div class="mb-4">
                                        <p class="fs-14 fw-medium text-gray mb-2">Tags</p>
                                        <div class="d-flex gap-2 flex-wrap" id="summaryTags">
                                            <span class="text-muted">No tags added</span>
                                        </div>
                                    </div>
                                    <div class="mb-4">
                                        <p class="fs-14 fw-medium text-gray mb-2">Files Uploaded</p>
                                        <span class="fs-14 text-dark" id="summaryFileCount">0</span>
                                    </div>
                                    <div class="mb-4">
                                        <p class="fs-14 fw-medium text-gray mb-2">Compliance Document</p>
                                        <span class="badge bg-soft-success fs-12 fw-normal text-success" id="summaryCompliance">No</span>
                                    </div>
                                    <div class="mb-4">
                                        <p class="fs-14 fw-medium text-gray mb-2">Restricted Access</p>
                                        <span class="badge bg-soft-danger fs-12 fw-normal text-danger" id="summaryAccess">No</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-end">
                    <button class="btn btn-primary rounded-pill" type="submit" id="submitBtn">
                        <%= isEdit ? "Update Document" : "Add Document" %>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <div class="footer mt-4 d-sm-flex align-items-center justify-content-between border-top bg-white p-3">
        <p class="mb-0">2025 &copy; HLFPPT.</p>
        <p>Designed & Developed by <a href="javascript:void(0);" class="text-primary">Duplex services & Technology</a></p>
    </div>
</div>
<!-- /Page Wrapper -->

<!-- Success Modal -->
