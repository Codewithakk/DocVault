        populateParentFoldersWithHierarchy(projectId, departmentId);
        
        // Show modal
        const modal = new bootstrap.Modal(document.getElementById('createFolderModal'));
        modal.show();
        
        // Enable/disable create button based on validations
        function validateModalForm() {
            const folderName = $('#newFolderName').val().trim();
            const parentFolder = $('#parentFolderSelect').val();
            const isValid = folderName !== '' && parentFolder && parentFolder !== '';
            $('#confirmCreateFolder').prop('disabled', !isValid);
        }
        
        // Validate on changes
        $('#newFolderName').on('input', validateModalForm);
