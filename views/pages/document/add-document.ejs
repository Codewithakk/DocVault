// =============================================
// FOLDER FUNCTIONS
// =============================================

async function buildDynamicFolderTree() {
    const projectId = $('#projectName').val();
    const departmentId = $('#department').val();
    
    if ((!projectId || projectId === 'all') || (!departmentId || departmentId === 'all')) {
        $('#dynamicFolderTree').html('<li class="text-muted p-3">Please select project and department</li>');
        $('#dynamicFolderGrid').html('<p class="text-muted p-3">Please select project and department</p>');
        window.folderTreeData = [];
        return;
    }
    
    const query = new URLSearchParams();
    if (departmentId && departmentId !== 'all') query.append('departmentId', departmentId);
    if (projectId && projectId !== 'all') query.append('projectId', projectId);
    
    try {
        $('#folderTreeLoader').removeClass('d-none');
        $('#folderGridLoader').removeClass('d-none');
        
        const res = await fetch(`/api/folders/tree/structure?${query.toString()}`);
        const data = await res.json();
        
        if (!data.success || !data.tree || data.tree.length === 0) {
            $('#dynamicFolderTree').html('<li class="text-muted p-3">No folders found</li>');
            $('#dynamicFolderGrid').html('<p class="text-muted p-3">No folders found</p>');
            return;
        }
        
        window.folderTreeData = data.tree;
        renderFolderTree(data.tree);
        renderFolderGrid(data.tree);
        
    } catch (err) {
        console.error("Error building folder tree:", err);
        $('#dynamicFolderTree').html('<li class="text-danger p-3">Error loading folders</li>');
        $('#dynamicFolderGrid').html('<p class="text-danger p-3">Error loading folders</p>');
    } finally {
        $('#folderTreeLoader').addClass('d-none');
        $('#folderGridLoader').addClass('d-none');
    }
}
function populateParentFolders(projectId, departmentId) {
    const select = $('#parentFolderSelect');
    select.empty().append('<option value="">-- Root Folder --</option>');
    
    fetch(`/api/folders/tree/structure?projectId=${projectId}&departmentId=${departmentId}`)
        .then(res => res.json())
        .then(data => {
            if (data.success && data.tree) {
                const flatFolders = flattenFolderTree(data.tree);
                flatFolders.forEach(folder => {
                    select.append(`<option value="${folder._id}">${folder.name}</option>`);
                });
                select.select2({
                    placeholder: "Select parent folder (optional)",
                    allowClear: true
                });
            }
        })
        .catch(err => console.error('Error loading parent folders:', err));
}

async function createNewFolder(projectId, departmentId, modal) {
    const folderName = $('#newFolderName').val().trim();
    const parentFolderId = $('#parentFolderSelect').val();
    
    // Validate
    let isValid = true;
    
    if (!folderName) {
        $('#newFolderName').addClass('is-invalid');
        isValid = false;
    } else {
        $('#newFolderName').removeClass('is-invalid');
    }
    
    if (!parentFolderId || parentFolderId === '') {
        $('#parentFolderSelect').addClass('is-invalid');
        isValid = false;
    } else {
        $('#parentFolderSelect').removeClass('is-invalid');
    }
    
    if (!isValid) {
        showToast('Please fill in all required fields', 'warning');
        return;
    }
    
    const confirmBtn = $('#confirmCreateFolder');
    confirmBtn.prop('disabled', true).html(
        '<span class="spinner-border spinner-border-sm me-1"></span> Creating...'
    );
    
    try {
        const response = await fetch('/api/folders', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                name: folderName,
                projectId: projectId,
                departmentId: departmentId,
                parentId: parentFolderId
            })
        });
        
        const data = await response.json();
        
        if (!data.success) {
            throw new Error(data.message || 'Failed to create folder');
        }
        
        // Close modal
        modal.hide();
        
        // Show success message with folder path
        const parentPath = findFolderPathById(parentFolderId, window.folderTreeData);
        const fullPath = parentPath ? parentPath.map(f => f.name).join(' / ') : '';
        showToast(
            data.message || `Folder "${folderName}" created successfully in: ${fullPath}`,
            'success'
        );
        
        // Refresh folder tree
        await loadFolders();
        await buildDynamicFolderTree();
        
        // Auto-select the new folder
        setTimeout(() => {
            const newFolder = findFolderById(data.data.folder._id);
            if (newFolder) {
                updateFolderSelection(newFolder);
                // Show a notification that folder is selected
                showToast(`Folder "${folderName}" is now selected`, 'info');
            }
        }, 500);
        
    } catch (error) {
        showToast(error.message, 'error');
    } finally {
        confirmBtn.prop('disabled', false).html('<i class="ti ti-plus me-1"></i> Create Folder');
    }
}

function populateParentFoldersWithHierarchy(projectId, departmentId) {
    const select = $('#parentFolderSelect');
    select.empty().append('<option value="">-- Select Parent Folder --</option>');
    
    // Show loading
    select.prop('disabled', true);
    
    fetch(`/api/folders/tree/structure?projectId=${projectId}&departmentId=${departmentId}`)
        .then(res => res.json())
        .then(data => {
            if (data.success && data.tree) {
                // Build options with hierarchy display
                const options = buildHierarchyOptions(data.tree);
                options.forEach(opt => {
                    select.append(`<option value="${opt.id}">${opt.display}</option>`);
                });
                
                // Enable select
                select.prop('disabled', false);
                
                // Initialize select2 with search
                select.select2({
                    placeholder: "Search for parent folder...",
                    allowClear: false,
                    width: '100%',
                    dropdownParent: $('#createFolderModal .modal-body')
                });
                
                // Auto-select root if available
                if (data.tree.length > 0) {
                    // Optionally set default to root
                    // select.val(data.tree[0]._id).trigger('change');
                }
            }
        })
        .catch(err => {
            console.error('Error loading parent folders:', err);
            select.append('<option value="" disabled>Error loading folders</option>');
            select.prop('disabled', false);
        });
}

function buildHierarchyOptions(treeData, prefix = '', level = 0) {
    let options = [];
    
    treeData.forEach(folder => {
        const displayName = prefix + folder.name;
        options.push({
            id: folder._id,
            display: displayName,
            level: level
        });
        
        if (folder.children && folder.children.length > 0) {
            const childOptions = buildHierarchyOptions(
                folder.children, 
                prefix + folder.name + ' / ', 
                level + 1
            );
            options = options.concat(childOptions);
        }
    });
    
    return options;
}

function updateParentPathDisplay(parentId) {
    const pathDisplay = $('#selectedParentPath');
    if (!pathDisplay.length) return;
    
    if (!parentId || parentId === '') {
        pathDisplay.html(`
            <i class="ti ti-folder text-primary me-2"></i>
            <span class="text-muted">Select a parent folder</span>
        `);
        return;
    }
    
    // Find the folder path
    const folderPath = findFolderPathById(parentId, window.folderTreeData);
    if (folderPath && folderPath.length > 0) {
        const pathString = folderPath.map(f => f.name).join(' / ');
        pathDisplay.html(`
            <i class="ti ti-folder text-primary me-2"></i>
            <span style="font-weight: 500;">${escapeHtml(pathString)}</span>
        `);
    } else {
        pathDisplay.html(`
            <i class="ti ti-folder text-primary me-2"></i>
            <span class="text-muted">Folder path not found</span>
        `);
    }
}

function findFolderPathById(folderId, treeData = null, currentPath = []) {
    if (!treeData) treeData = window.folderTreeData;
    if (!treeData) return null;
    
    for (const folder of treeData) {
        const newPath = [...currentPath, { id: folder._id, name: folder.name }];
        if (folder._id === folderId) {
            return newPath;
        }
        if (folder.children && folder.children.length > 0) {
            const found = findFolderPathById(folderId, folder.children, newPath);
            if (found) return found;
        }
    }
    return null;
}
