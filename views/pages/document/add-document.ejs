    <div class="modal-dialog modal-notificationslike">
        <div class="modal-content">
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            <div class="modal-body">
                <div class="success_mdltxt text-center">
                    <div class="imgscs mb-3"><img src="/img/icons/success.png" style="max-width: 60px;"></div>
                    <div class="d-flex align-items-center justify-content-center mb-2">
                        <span class="avatar avatar-xs rounded bg-light mb-2">
                            <img src="/img/icons/fn1.png">
                        </span>
                        <div class="ms-2">
                            <p class="fs-12 mb-1 fw-medium" id="successFileName">Project Proposal v1</p>
                        </div>
                    </div>
                    <h4 class="fs-16 text-dark fw-medium mb-2">Your File <%= isEdit ? "Updated" : "Added" %> Successfully</h4>
                    <p class="fs-14 fw-normal mb-3">You will be notified soon as your file gets approved</p>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>

<script>
// =============================================
// COMPLETE DOCUMENT ADD/EDIT SCRIPT
// =============================================
$(document).ready(function () {
    // Force header project select to work independently
    if (typeof initializeHeaderComponents === 'function') {
        setTimeout(initializeHeaderComponents, 100);
    }
});
// Global state
window.isEdit = <%= isEdit ? 'true' : 'false' %>;
window.documentId = "<%= isEdit && document ? document._id : '' %>";
window.documentData = <%= isEdit && document ? JSON.stringify(document) : 'null' %>;
window.selectedFolders = [];
window.uploadedFilesMetadata = [];
window.folderTreeData = [];
window.uploadedFileIds = [];

$(document).ready(function() {
    // Initialize components
    initializeSelect2();
    initializeSummernote();
    initializeDatepicker();
    setupEnhancedDateRestrictions();
    initializeEditData();
    loadInitialData();
    setupFileUpload();
    setupFormSubmission();
    setupSummaryUpdate();
    
    // Setup create folder button
    setupCreateFolderButton();
    
    // Initial state for create folder button
    toggleCreateFolderBtn();
    
    // Handle modal cleanup
    $(document).on('hidden.bs.modal', '#createFolderModal', function() {
        // Clean up select2 to prevent memory leaks
        if ($.fn.select2) {
            $('#parentFolderSelect').select2('destroy');
        }
        $('#createFolderModal').remove();
    });
});
function formatDateForDisplay(dateString) {
    if (!dateString) return '';
    const date = new Date(dateString);
    if (isNaN(date.getTime())) return '';
    return date.toLocaleDateString('en-GB'); // DD/MM/YYYY format
}
function toggleCreateFolderBtn() {
    const projectSelected = !!$('#projectName').val() && $('#projectName').val() !== 'all';
    const departmentSelected = !!$('#department').val() && $('#department').val() !== 'all';
    const isEnabled = projectSelected && departmentSelected;

    // Update Create Folder button
    $('#createFolderBtn')
        .prop('disabled', !isEnabled)
        .css({
            'opacity': isEnabled ? '1' : '0.5',
            'cursor': isEnabled ? 'pointer' : 'not-allowed'
        })
        .attr('title', isEnabled ? 'Create new folder in this department' : 'Please select both Project and Department');

    // Enable/disable Upload Box
    if (projectSelected && departmentSelected) {
        $('#uploadBox').css({ 'pointer-events': '', 'opacity': '' });
    } else {
        $('#uploadBox').css({ 'pointer-events': 'none', 'opacity': 0.6 });
    }
}
// Helper function to format date for server
// Helper function to format date for server - supports multiple input formats
function formatDateForServer(dateString) {
    if (!dateString) return '';
    
    // If already in YYYY-MM-DD format, return as is
    if (/^\d{4}-\d{2}-\d{2}$/.test(dateString)) {
        return dateString;
    }
    
    // Try to parse DD/MM/YYYY or DD-MM-YYYY
    let parts = dateString.split(/[/-]/);
    if (parts.length === 3) {
        // If year is 2 digits, assume 20xx
        if (parts[2].length === 2) {
            parts[2] = '20' + parts[2];
        }
        // Return in YYYY-MM-DD format
        return `${parts[2]}-${parts[1].padStart(2, '0')}-${parts[0].padStart(2, '0')}`;
    }
    
    // Try to parse using moment.js
    const momentDate = moment(dateString, ['DD-MM-YYYY', 'DD/MM/YYYY', 'YYYY-MM-DD', 'MM-DD-YYYY'], true);
    if (momentDate.isValid()) {
        return momentDate.format('YYYY-MM-DD');
    }
    
    // If all parsing fails, return original
    return dateString;
}
// =============================================
// INITIALIZATION FUNCTIONS
// =============================================

function initializeSelect2() {
    $('.select2').select2();

    // Project Name Select2 with AJAX
    $("#projectName").select2({
        placeholder: "-- Select Project Name --",
        allowClear: true,
        ajax: {
            delay: 300,
            transport: function(params, success, failure) {
                const search = params.data.term || "";
                $.ajax({
                    url: `/api/projects?search=${encodeURIComponent(search)}`,
                    type: "GET",
                    success: function(res) {
                        let data = res.data || [];
                        success(data);
                    },
                    error: failure
                });
            },
            processResults: function(data) {
                return {
                    results: data.map(project => ({
                        id: project._id,
                        text: project.projectName
                    }))
                };
            }
        }
    });

    // Department Select2 with AJAX
    $("#department").select2({
        placeholder: "-- Select Department --",
        allowClear: true,
        ajax: {
            url: '/api/departments/search',
            dataType: 'json',
            delay: 250,
            data: function(params) {
                return { search: params.term || '', page: params.page || 1, limit: 10 };
            },
            processResults: function(data, params) {
                params.page = params.page || 1;
                let results = data.data.map(dep => ({ id: dep._id, text: dep.name }));
                return { results, pagination: { more: data.pagination.more } };
            },
            cache: true
        }
    });

    // Donor Select2
    initializeDonorSelect2();
    
    // Vendor Select2
    initializeVendorSelect2();

    // Pre-select values if editing
    if (window.isEdit && window.documentData) {
        if (window.documentData.project) {
            const projectOption = new Option(
                window.documentData.project.projectName,
                window.documentData.project._id,
                true,
                true
            );
            $('#projectName').append(projectOption).trigger('change');
        }
        if (window.documentData.department) {
            const departmentOption = new Option(
                window.documentData.department.name,
                window.documentData.department._id,
                true,
                true
            );
            $('#department').append(departmentOption).trigger('change');
        }
    }

    // Pre-select from session if not editing
    <% if (!isEdit && selectedProject && selectedProject._id) { %>
        const userProject = { id: "<%= selectedProject._id %>", name: "<%= selectedProject.projectName %>" };
        const projectOption = new Option(userProject.name, userProject.id, true, true);
        $('#projectName').append(projectOption).trigger('change');
    <% } %>
}

function initializeSummernote() {
    $('.summernote').summernote({
        height: 200,
        callbacks: {
            onChange: function(contents) {
                $('#summernote').val(contents);
            }
        }
    });
}

function initializeDatepicker() {
    $('.datetimepicker').datetimepicker({
        format: 'DD-MM-YYYY',
        useCurrent: false
    });
}

function setupEnhancedDateRestrictions() {
    const today = moment().startOf('day');
    const expiryDatePicker = $('input[name="expiryDate"]').datetimepicker({
        format: 'DD-MM-YYYY',
        useCurrent: false,
        minDate: today
    });
    expiryDatePicker.data("DateTimePicker").disable();

    $('#complianceSwitch').change(function() {
        const expiryPicker = expiryDatePicker.data("DateTimePicker");
        if ($(this).is(':checked')) {
            expiryPicker.enable();
            expiryPicker.minDate(today);
            $('#expiryDateContainer').show();
            $('input[name="expiryDate"]').prop('required', true);
        } else {
            expiryPicker.clear();
            expiryPicker.disable();
            $('#expiryDateContainer').hide();
            $('input[name="expiryDate"]').prop('required', false);
        }
    });
}

function initializeDonorSelect2() {
    $('#documentDonor').select2({
        placeholder: '-- Select Donor Name --',
        allowClear: true,
        ajax: {
            url: '/api/user/search',
            dataType: 'json',
            delay: 250,
            data: function(params) {
                const projectId = $('#projectName').val();
                return {
                    search: params.term || '',
                    page: params.page || 1,
                    limit: 10,
                    projectId: projectId,
                    profile_type: 'donor'
                };
            },
            processResults: function(data, params) {
                params.page = params.page || 1;
                const results = data.users.map(u => ({ id: u._id, text: u.name }));
                return {
                    results,
                    pagination: { more: params.page * 10 < data.pagination.total }
                };
            },
            cache: true
        },
        minimumInputLength: 0
    });

    if (window.isEdit && window.documentData && window.documentData.documentDonor) {
        const donorOption = new Option(
            window.documentData.documentDonor.name,
            window.documentData.documentDonor._id,
            true,
            true
        );
        $('#documentDonor').append(donorOption).trigger('change');
    }
}

function initializeVendorSelect2() {
    $('#documentVendor').select2({
        placeholder: '-- Select Vendor Name --',
        allowClear: true,
        ajax: {
            url: '/api/user/search',
            dataType: 'json',
            delay: 250,
            data: function(params) {
                const projectId = $('#projectName').val();
                return {
                    search: params.term || '',
                    page: params.page || 1,
                    limit: 10,
                    projectId: projectId,
                    profile_type: 'vendor'
                };
            },
            processResults: function(data, params) {
                params.page = params.page || 1;
                const results = data.users.map(u => ({ id: u._id, text: u.name }));
                return {
                    results,
                    pagination: { more: params.page * 10 < data.pagination.total }
                };
            },
            cache: true
        },
        minimumInputLength: 0
    });

    if (window.isEdit && window.documentData && window.documentData.documentVendor) {
        const vendorOption = new Option(
            window.documentData.documentVendor.name,
            window.documentData.documentVendor._id,
            true,
            true
        );
        $('#documentVendor').append(vendorOption).trigger('change');
    }
}

function initializeEditData() {
    if (!window.isEdit || !window.documentData) return;

    // Initialize folder selection
    if (window.documentData.folderId) {
        const folderId = window.documentData.folderId._id || window.documentData.folderId;
        const folderName = window.documentData.folderId.name || 'Selected Folder';
        window.selectedFolders = [{ id: folderId, name: folderName }];
        $('#selectedFolderId').val(folderId);
    }

    // Initialize metadata
    if (window.documentData.metadata) {
        populateMetadataFields(window.documentData.metadata);
    }

    // Initialize uploaded files
    if (window.documentData.files && window.documentData.files.length > 0) {
        window.uploadedFilesMetadata = window.documentData.files.map(file => ({
            fileName: file.originalName || file.name || 'Unknown',
            fileType: file.mimetype || file.type || 'Unknown',
            fileSize: formatFileSize(file.size || 0),
            uploadedBy: file.uploadedBy?.name || 'Unknown',
            uploadDate: file.createdAt ? new Date(file.createdAt).toLocaleString() : 'Unknown',
            fileId: file._id || file.id,
            fileUrl: file.fileUrl || ''
        }));
        window.uploadedFileIds = window.uploadedFilesMetadata.map(f => f.fileId);
        updateMetadataDisplay();
        updateFileList();
    }

    // Initialize tags
    if (window.documentData.tags && window.documentData.tags.length > 0) {
        $('input[name="tags"]').val(window.documentData.tags.join(', '));
    }

    // Initialize compliance
    if (window.documentData.compliance?.isCompliance) {
        $('#complianceSwitch').prop('checked', true);
        $('#expiryDateContainer').show();
        if (window.documentData.compliance.expiryDate) {
            $('input[name="expiryDate"]').val(
                new Date(window.documentData.compliance.expiryDate).toLocaleDateString('en-GB')
            );
        }
    }

    // Initialize wantApprovers
    if (window.documentData.wantApprovers?.iswantApprovers) {
        $('#wantApprovers').prop('checked', true);
    }

    // Initialize comment
    if (window.documentData.comment) {
        $('textarea[name="comment"]').val(window.documentData.comment);
    }
}

function populateMetadataFields(metadata) {
    if (metadata.fileName) {
        $('input[name="metadata[fileName]"]').val(metadata.fileName);
    }
}

