// =============================================

function updateSummary() {
    // Project
    const projectText = $('#projectName option:selected').text();
    $('#summaryProject').text(projectText && projectText !== '-- Select Project Name --' ? projectText : '--');

    // Department
    const departmentText = $('#department option:selected').text();
    $('#summaryDepartment').text(departmentText && departmentText !== '-- Select Department --' ? departmentText : '--');

    // Folder
    const folderPath = window.selectedFolders.map(f => f.name).join(' > ');
    $('#summaryFolder').text(folderPath || '--');

    // Tags
    const tagsText = $('input[name="tags"]').val() || '';
    const tags = tagsText.split(',').map(t => t.trim()).filter(t => t);
    const tagsContainer = $('#summaryTags');
    if (tags.length > 0) {
        tagsContainer.html(tags.map(t => `<span class="badge bg-light fs-12 fw-normal text-dark">${escapeHtml(t)}</span>`).join(' '));
    } else {
        tagsContainer.html('<span class="text-muted">No tags added</span>');
    }

    // File Count
    const fileCount = window.uploadedFilesMetadata.length;
    $('#summaryFileCount').text(fileCount);

    // Compliance
    const isCompliance = $('#complianceSwitch').is(':checked');
    $('#summaryCompliance').text(isCompliance ? 'Yes' : 'No').removeClass('bg-soft-success text-success bg-soft-danger text-danger')
        .addClass(isCompliance ? 'bg-soft-success text-success' : 'bg-soft-danger text-danger');

    // Restricted Access
    const isRestricted = $('#wantApprovers').is(':checked');
    $('#summaryAccess').text(isRestricted ? 'Yes' : 'No').removeClass('bg-soft-success text-success bg-soft-danger text-danger')
        .addClass(isRestricted ? 'bg-soft-danger text-danger' : 'bg-soft-success text-success');
}

function setupSummaryUpdate() {
    // Listen for changes that affect summary
    $('#projectName, #department').on('change', updateSummary);
    $('input[name="tags"]').on('input', updateSummary);
    $('#complianceSwitch, #wantApprovers').on('change', updateSummary);
}

