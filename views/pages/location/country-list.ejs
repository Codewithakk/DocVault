<%- include('../../partials/header') %>

<div class="page-wrapper">
    <div class="content">

        <!-- Breadcrumb -->
        <div class="dflexbtwn page-breadcrumb mb-3">
            <div class="my-auto mb-2">
                <h2 class="mb-1">Country List</h2>
                <nav>
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item">
                            <a href="#"><i class="ti ti-smart-home"></i></a>
                        </li>
                        <li class="breadcrumb-item active">Country List</li>
                    </ol>
                </nav>
            </div>
            <div>
                <a href="#" id="addCountryBtn" class="btn btn-primary">
                    <i class="ti ti-plus me-1"></i> Add Country
                </a>
            </div>
        </div>

        <!-- Table -->
        <div class="card">
            <div class="card-body p-0">
                <div class="custom-datatable-filter table-responsive">
                    <table class="table datatable" id="countryTable">
                        <thead class="thead-light">
                            <tr>
                                <th>Sr No.</th>
                                <th>Name</th>
                                <th>Created At</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="countryTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer mt-4 d-sm-flex justify-content-between border-top bg-white p-3">
            <p class="mb-0">2025 &copy; HLFPPT.</p>
            <p>Designed & Developed by 
                <a href="javascript:void(0);" class="text-primary">
                    Duplex Services & Technology
                </a>
            </p>
        </div>

    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="countryModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Country</h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Close">
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="countryId">
                <input type="text" id="countryName" class="form-control" placeholder="Country Name">
            </div>
            <div class="modal-footer">
                <button class="btn btn-success" id="saveCountry">Save</button>
            </div>
        </div>
    </div>
</div>

<%- include('../../modals/deleteModal') %>
<%- include('../../partials/footer') %>

<!-- DataTables -->
<link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<script>
$(document).ready(function () {

    let deleteId = null;
    let editMode = false;

    function loadCountries() {

$('#countryTable').DataTable({
    processing: true,
    serverSide: true,
    destroy: true,

    columnDefs: [
        { orderable: false, targets: [0, 3] }
    ],
    order: [],

    ajax: function (data, callback) {

        let page = (data.start / data.length) + 1;
        let search = data.search.value;

        $.get(`${baseUrl}/api/country`, {
            page: page,
            limit: data.length,
            search: search
        }, function (res) {

            let rows = [];

            res.data.forEach((c, i) => {
                rows.push([
                    data.start + i + 1,
                    c.name,
                    formatDateTime(c.createdAt),
                    `
                    <a href="#" class="text-primary me-2 btn-edit" 
                       data-item='${encodeURIComponent(JSON.stringify(c))}'>
                        <i class="ti ti-edit"></i>
                    </a>
                    <a href="#" class="text-danger btn-delete" 
                       data-id="${c._id}">
                        <i class="ti ti-trash"></i>
                    </a>
                    `
                ]);
            });

            callback({
                draw: data.draw,
                recordsTotal: res.total,
                recordsFiltered: res.total,
                data: rows
            });

        });
    }
});
}

    loadCountries();


    $('#addCountryBtn').click(function () {
        editMode = false;
        $('#countryId').val('');
        $('#countryName').val('');
        $('#modalTitle').text('Add Country');
        $('#countryModal').modal('show');
    });


    $('#saveCountry').click(function () {

        let id = $('#countryId').val();
        let name = $('#countryName').val().trim();

        if (!name) {
            showToast('Country name required', 'warning');
            return;
        }

        let url = `${baseUrl}/api/country`;
        let method = 'POST';

        if (editMode) {
            url += `/${id}`;
            method = 'PUT';
        }

        $('#saveCountry').prop('disabled', true);

        $.ajax({
            url,
            method,
            data: { name },
            success: function (res) {

                $('#saveCountry').prop('disabled', false);
                $('#countryModal').modal('hide');

                // Reset form
                $('#countryId').val('');
                $('#countryName').val('');
                editMode = false;

                if (res.success) {
                    showToast(res.message || 'Saved successfully', 'success');
                    loadCountries();
                } else {
                    showToast(res.message || 'Failed', 'danger');
                }
            },
            error: function () {
                $('#saveCountry').prop('disabled', false);
                showToast('Something went wrong', 'danger');
            }
        });
    });

    $(document).on('click', '.btn-edit', function (e) {
        e.preventDefault();

        editMode = true;

        let data = JSON.parse(decodeURIComponent($(this).attr('data-item')));

        $('#countryId').val(data._id);
        $('#countryName').val(data.name);
        $('#modalTitle').text('Edit Country');

        $('#countryModal').modal('show');
    });

    $(document).on('click', '.btn-delete', function (e) {
        e.preventDefault();
        deleteId = $(this).data('id');
        $('#confirmDeleteModal').modal('show');
    });

    $('#confirmDeleteBtn').click(function () {

        if (!deleteId) return;

        $.ajax({
            url: `${baseUrl}/api/country/${deleteId}`,
            method: 'DELETE',
            success: function (res) {

                $('#confirmDeleteModal').modal('hide');
                deleteId = null;

                if (res.success) {
                    showToast(res.message || 'Deleted successfully', 'success');
                    loadCountries();
                } else {
                    showToast(res.message || 'Delete failed', 'danger');
                }
            },
            error: function () {
                showToast('Delete error', 'danger');
            }
        });
    });

});
</script>
