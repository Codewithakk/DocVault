<%- include('../../partials/header') %>

<!-- Page Wrapper -->
<div class="page-wrapper">
    <div class="content">
        <!-- Breadcrumb -->
        <div class="d-flex align-items-center justify-content-between page-breadcrumb mb-3">
            <div class="my-auto mb-2">
                <h2 class="mb-1">My Approvals</h2>
                <nav>
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item">
                            <a href="#"><i class="ti ti-smart-home"></i></a>
                        </li>
                        <li class="breadcrumb-item">
                            Dashboard
                        </li>
                        <li class="breadcrumb-item">
                            Approvals
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
        <!-- /Breadcrumb -->

        <div class="row">
            <div class="seprate_crdhdr mb-4">
                <div class="d-flex flex-column flex-wrap gap-2">
                    <div class="d-flex flex-wrap gap-3 mb-2">
                        <button type="button" class="d-flex gap-2 align-items-center btn btn-outline-light shadow-sm rounded-3 status-tab" data-status="All">
                            <span class="avatar avatar-lg bg-soft-primary text-primary">
                                <i class="ti ti-folder fs-24"></i>
                            </span>
                            <div class="fltrtxt text-start">
                                <h5 class="fs-14 mb-1 fw-medium">All</h5>
                                <h4 class="fs-21 mb-1 count-display" id="count-All">0</h4>
                                <p class="text-gray-7 fw-normal">Documents</p>
                            </div>                            
                        </button>
                        <button type="button" class="d-flex gap-2 align-items-center btn btn-outline-light shadow-sm rounded-3 status-tab" data-status="Pending">
                            <span class="avatar avatar-lg bg-soft-warning text-warning">
                                <i class="ti ti-clock fs-24"></i>
                            </span>
                            <div class="fltrtxt text-start">
                                <h5 class="fs-14 mb-1 fw-medium">Pending</h5>
                                <h4 class="fs-21 mb-1 count-display" id="count-Pending">0</h4>
                                <p class="text-gray-7 fw-normal">Documents</p>
                            </div>                            
                        </button>
                        <button type="button" class="d-flex gap-2 align-items-center btn btn-outline-light shadow-sm rounded-3 status-tab" data-status="Approved">
                            <span class="avatar avatar-lg bg-soft-success text-success">
                                <i class="ti ti-folder-check fs-24"></i>
                            </span>
                            <div class="fltrtxt text-start">
                                <h5 class="fs-14 mb-1 fw-medium">Approved</h5>
                                <h4 class="fs-21 mb-1 count-display" id="count-Approved">0</h4>
                                <p class="text-gray-7 fw-normal">Documents</p>
                            </div>                            
                        </button>
                        <button type="button" class="d-flex gap-2 align-items-center btn btn-outline-light shadow-sm rounded-3 status-tab" data-status="Rejected">
                            <span class="avatar avatar-lg bg-soft-danger text-danger">
                                <i class="ti ti-folder-x fs-24"></i>
                            </span>
                            <div class="fltrtxt text-start">
                                <h5 class="fs-14 mb-1 fw-medium">Rejected</h5>
                                <h4 class="fs-21 mb-1 count-display" id="count-Rejected">0</h4>
                                <p class="text-gray-7 fw-normal">Documents</p>
                            </div>                            
                        </button>
                        <!-- <button type="button" class="d-flex gap-2 align-items-center btn btn-outline-light shadow-sm rounded-3 status-tab" data-status="Draft">
                            <span class="avatar avatar-lg bg-soft-primary text-primary">
                                <i class="ti ti-folder-pause fs-24"></i>
                            </span>
                            <div class="fltrtxt text-start">
                                <h5 class="fs-14 mb-1 fw-medium">Draft</h5>
                                <h4 class="fs-21 mb-1 count-display" id="count-Draft">0</h4>
                                <p class="text-gray-7 fw-normal">Documents</p>
                            </div>                            
                        </button> -->
                    </div>

                    <div class="d-flex align-items-center gap-2 flex-wrap ms-auto">
                        <div class="position-relative mb-0">
                            <input type="text" class="form-control pe-6" id="documentDate"
                                placeholder="Select Date Range" readonly style="margin-right:10px">
                            <!-- Calendar Icon -->
                            <span class="calendar-icon">
                                <i class="ti ti-calendar text-gray-7"></i>
                            </span>
                            <!-- Clear Button (×) -->
                            <button type="button" id="clearDateRange" class="btn-close clear-btn"
                                title="Clear date range">
                            </button>
                        </div>
                        <div class="mb-0">
                            <select id="department" class="form-select select2" style="width: 200px;">
                                <option value="">-- Select Department --</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xxl-12 col-xl-12">
                <div class="card flex-fill">
                    <div class="card-body p-0">
                        <div class="custom-datatable-filter table-responsive">
                            <table id="approvalTable" class="table datatable">
                                <thead>
                                    <tr>
                                        <th>Action</th>
                                        <th>Track</th>
                                        <th>File Name</th>
                                        <th>Created Date</th>
                                        <th>Department</th>
                                        <th>Approver</th>
                                        <th>Request Status</th>
                                        <th>Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Data will be injected via Ajax -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="footer mt-4 d-sm-flex align-items-center justify-content-between border-top bg-white p-3">
        <p class="mb-0">2025 &copy; HLFPPT.</p>
        <p>Designed & Developed by <a href="javascript:void(0);" class="text-primary">Duplex services &
                Technology</a></p>
    </div>
</div>
<!-- /Page Wrapper -->

<%- include('../../partials/footer') %>

<!-- Scripts -->
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script src="/js/components/shareDocument.js"></script>

<!-- Only font color fix for selected status tabs -->
<style>
    /* Make text white when status tab is selected */
    .status-tab.btn-primary .fltrtxt h5,
    .status-tab.btn-primary .fltrtxt h4,
    .status-tab.btn-primary .fltrtxt p {
        color: #ffffff !important;
    }
</style>

<script>
    $(document).ready(function () {
        // Get document ID from URL if present
        const urlParams = new URLSearchParams(window.location.search);
        const documentId = urlParams.get('id') || '';

        // File icons mapping
        const fileIcons = {
            ppt: "/img/icons/fn1.png",
            pptx: "/img/icons/fn1.png",
            doc: "/img/icons/fn2.png",
            docx: "/img/icons/fn2.png",
            xls: "/img/icons/fn3.png",
            xlsx: "/img/icons/fn3.png",
            pdf: "/img/icons/fn4.png",
            default: "/img/icons/fn1.png"
        };

        // Status badge class mapping
        const statusClassMap = {
            'draft': 'bg-soft-info text-info',
            'pending': 'bg-soft-warning text-warning',
            'approved': 'bg-soft-success text-success',
            'rejected': 'bg-soft-danger text-danger',
            'underreview': 'bg-soft-warning text-warning',
            'archived': 'bg-soft-secondary text-secondary'
        };

        // Date range state
        let selectedDateRange = null;

        // Initialize Flatpickr for date range
        const fp = flatpickr("#documentDate", {
            mode: "range",
            dateFormat: "d-m-Y",
            allowInput: false,
            clickOpens: true,
            locale: {
                rangeSeparator: " to "
            },
            onChange: function (selectedDates, dateStr, instance) {
                if (selectedDates.length === 2) {
                    selectedDateRange = {
                        start: selectedDates[0],
                        end: selectedDates[1]
                    };
                    document.getElementById("clearDateRange").style.display = "block";
                    fetchCounts();
                    table.ajax.reload();
                }
            },
            onClose: function (selectedDates) {
                if (selectedDates.length < 2 && selectedDates.length > 0) {
                    setTimeout(() => {
                        fp.clear();
                    }, 100);
                }
                if (selectedDates.length === 0) {
                    selectedDateRange = null;
                    document.getElementById("clearDateRange").style.display = "none";
                    fetchCounts();
                    table.ajax.reload();
                }
            }
        });

        // Clear date range
        document.getElementById("clearDateRange").addEventListener("click", function () {
            fp.clear();
            selectedDateRange = null;
            this.style.display = "none";
            fetchCounts();
            table.ajax.reload();
        });

        // Helper function to format date
        function formatDateTime(dateStr) {
            if (!dateStr) return '-';
            try {
                const date = new Date(dateStr);
                if (isNaN(date.getTime())) return '-';
                return date.toLocaleString('en-IN', {
                    day: '2-digit',
                    month: 'short',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit',
                    hour12: true
                });
            } catch (e) {
                return '-';
            }
        }

        // Helper function to format bytes
        function formatBytes(bytes, decimals = 2) {
            if (!bytes || bytes === 0) return '';
            const k = 1024;
            const dm = decimals < 0 ? 0 : decimals;
            const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
        }

        // Function to fetch counts from the API
        function fetchCounts() {
            const department = $('#department').val() || '';
            const startDate = selectedDateRange ? selectedDateRange.start.toISOString() : '';
            const endDate = selectedDateRange ? selectedDateRange.end.toISOString() : '';

            $.ajax({
                url: '/api/approval-requests-counts',
                type: 'GET',
                credentials: 'include',
                data: {
                    department: department,
                    startDate: startDate,
                    endDate: endDate
                },
                success: function(response) {
                    if (response.success && response.data) {
                        // Update count displays
                        if (response.data.All !== undefined) {
                            $('#count-All').text(response.data.All);
                        }
                        if (response.data.Pending !== undefined) {
                            $('#count-Pending').text(response.data.Pending);
                        }
                        if (response.data.Approved !== undefined) {
                            $('#count-Approved').text(response.data.Approved);
                        }
                        if (response.data.Rejected !== undefined) {
                            $('#count-Rejected').text(response.data.Rejected);
                        }
                        if (response.data.Draft !== undefined) {
                            $('#count-Draft').text(response.data.Draft);
                        }
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error fetching counts:', error);
                }
            });
        }

        // Initialize DataTable
        const table = $('#approvalTable').DataTable({
            ajax: {
                url: '/api/approval-requests',
                type: 'GET',
                credentials: 'include',
                data: function (d) {
                    // Get status from active tab using data-status attribute
                    const activeTab = $('.status-tab.btn-primary');
                    let status = 'All';
                    
                    if (activeTab.length > 0) {
                        status = activeTab.data('status') || 'All';
                    }
                    
                    d.status = status;
                    d.documentId = documentId;
                    d.department = $('#department').val() || '';
                    
                    if (selectedDateRange) {
                        d.startDate = selectedDateRange.start.toISOString();
                        d.endDate = selectedDateRange.end.toISOString();
                    } else {
                        d.startDate = '';
                        d.endDate = '';
                    }
                },
                dataSrc: function (json) {
                    if (!json.data || !Array.isArray(json.data)) {
                        return [];
                    }
                    
                    return json.data.map(item => {
                        const file = item.files || null;
                        const fileExt = file?.originalName?.split('.').pop().toLowerCase() || '';
                        const fileIcon = fileIcons[fileExt] || fileIcons.default;
                        const fileSize = file?.fileSize || null;
                        const isApproved = (item.status || '').toLowerCase() === 'approved';
                        // File info HTML
                        const fileInfoHtml = file ? `
                            <div class="d-flex align-items-center">
                                <span class="avatar rounded bg-light me-2">
                                    <img src="${fileIcon}" alt="icon" style="height:30px; width:30px; object-fit:contain;">
                                </span>
                                <div>
                                    <p class="mb-0 text-dark">${item.metadata?.fileName || file?.originalName || '-'}</p>
                                    ${fileSize ? `<small class="text-muted">${fileSize}</small>` : ''}
                                </div>
                            </div>
                        ` : '-';

                        // Status badge
                        const statusKey = (item.status || '').toLowerCase().replace(/\s+/g, '');
                        const statusClass = statusClassMap[statusKey] || 'bg-soft-secondary text-secondary';
                        
                        // Approver names
                        let approverNames = [];
                        if (item.projectManager?.name) {
                            approverNames.push(item.projectManager.name);
                        }
                        if (item.sharedWithUsers?.length) {
                            approverNames.push(...item.sharedWithUsers.map(u => u.name));
                        }

                        let approversHtml = '-';
                        const totalApprovers = approverNames.length;

                        if (totalApprovers > 2) {
                            const tooltipText = approverNames.join(", ");
                            approversHtml = `
                                <span class="approver-tooltip" data-bs-toggle="tooltip" title="${tooltipText}">
                                    ${approverNames[0]} 
                                    <span class="text-success">+${totalApprovers - 1}</span>
                                </span>
                            `;
                        } else if (totalApprovers > 0) {
                            approversHtml = approverNames.join(", ");
                        }

                        // Actions dropdown
                        const actionsDropdown = `
                            <div class="btn-group" role="group">
                                <button type="button" class="btn border-0" data-bs-toggle="dropdown">
                                    <i class="ti ti-settings"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="/documents/${item._id}/versions/view?version="><i class="ti ti-eye"></i> View</a></li>
                                    <li><a class="dropdown-item" href="/documents/edit/${item._id}"><i class="ti ti-pencil-minus"></i> Edit</a></li>
                                    <li>
                                        <a class="dropdown-item" 
                                           href="#" 
                                           data-bs-toggle="modal" 
                                           data-bs-target="#sharedoc-modal"
                                           data-doc-id="${item._id}"
                                           data-file-id="${item.files?._id || ''}">
                                            <i class="ti ti-share"></i> Share
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" 
                                           href="#" 
                                           data-bs-toggle="modal" 
                                           data-bs-target="#versionhistory-modal"
                                           data-id="${item._id}">
                                            <i class="ti ti-history"></i> Version History
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" 
                                           href="#" 
                                           data-bs-toggle="modal" 
                                           data-file-id="${item._id || ''}" 
                                           data-bs-target="#downloaddoc-modal">
                                            <i class="ti ti-download"></i> Download
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item btn-delete" 
                                           href="#" 
                                           data-id="${item._id}" 
                                           data-bs-toggle="modal" 
                                           data-bs-target="#trashdoc-modal">
                                            <i class="ti ti-trash"></i> Move to Trash
                                        </a>
                                    </li>
                                    ${!isApproved ? `
                                    <li>
                                        <a class="dropdown-item archive-document" 
                                           href="#" 
                                           data-id="${item._id}" 
                                           data-bs-toggle="modal" 
                                           data-bs-target="#archivedoc-modal">
                                            <i class="ti ti-archive"></i> Move to Archive
                                        </a>
                                    </li>` : ''}
                                </ul>
                            </div>
                        `;

                        return {
                            "0": actionsDropdown,
                            "1": `<button class="btn btn-outline-primary track-btn" data-id="${item._id}">Track</button>`,
                            "2": fileInfoHtml,
                            "3": `<p class="tbl_date">${formatDateTime(item.documentDate || item.createdAt || item.updatedAt)}</p>`,
                            "4": item.department?.name || '-',
                            "5": approversHtml,
                            "6": `<span class="badge badge-md ${statusClass}">${item.status}</span>`,
                            "7": `<p>${item.comment || '-'}</p>`
                        };
                    });
                },
                error: function(xhr, status, error) {
                    console.error('DataTable AJAX Error:', error);
                    console.error('Status:', status);
                    console.error('Response:', xhr.responseText);
                }
            },
            columns: [
                { data: "0" },
                { data: "1" },
                { data: "2" },
                { data: "3" },
                { data: "4" },
                { data: "5" },
                { data: "6" },
                { data: "7" }
            ],
            order: [[1, "asc"]],
            columnDefs: [
                { orderable: false, targets: [0, 5, 6] }
            ],
            language: {
                emptyTable: "No approval requests found",
                loadingRecords: "Loading..."
            }
        });

        // Set "All" as default active status
        $('.status-tab:first').removeClass('btn-outline-light').addClass('btn-primary');

        // Status filter click handler
        $('.status-tab').on('click', function () {
            // Remove active class from all status tabs
            $('.status-tab').removeClass('btn-primary').addClass('btn-outline-light');
            // Add active class to clicked tab
            $(this).removeClass('btn-outline-light').addClass('btn-primary');
            table.ajax.reload();
        });

        // Track button click handler
        $('#approvalTable').on('click', '.track-btn', function () {
            const docId = $(this).data('id');
            if (docId) {
                window.location.href = `/document/${docId}/approval/track`;
            }
        });

        // Department filter
        $('#department').on('change', function () {
            fetchCounts();
            table.ajax.reload();
        });

        // Initialize Select2 for department
        function initSelect2(selector, url, textKey) {
            $(selector).select2({
                placeholder: '-- Select Department --',
                allowClear: true,
                ajax: {
                    url: url,
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return {
                            search: params.term || ''
                        };
                    },
                    processResults: function (data) {
                        const results = [
                            { id: '', text: '-- Select Department --' }
                        ];
                        
                        if (data && data.data && Array.isArray(data.data)) {
                            data.data.forEach(function(item) {
                                results.push({
                                    id: item._id,
                                    text: item[textKey] || item.name || 'Unknown'
                                });
                            });
                        }
                        
                        return { results: results };
                    },
                    cache: true
                },
                minimumInputLength: 0
            });

            // Handle clear selection
            $(selector).on('select2:select', function (e) {
                if (e.params.data.id === '') {
                    $(this).val(null).trigger('change');
                }
            });
        }

        // Initialize department dropdown
        if ($('#department').length) {
            initSelect2('#department', '/api/departments/search', 'name');
        }

        // Initialize tooltips
        setTimeout(function() {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(t) {
                new bootstrap.Tooltip(t);
            });
        }, 500);

        // Fetch counts on page load
        fetchCounts();

        // Refresh counts periodically (every 60 seconds)
        setInterval(fetchCounts, 60000);

    });
</script>