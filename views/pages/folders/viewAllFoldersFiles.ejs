        <script>
            // Image extensions
            // const imageExtensions = ['jpg', 'jpeg', 'png', 'gif', 'svg', 'webp', 'bmp', 'ico'];
            const projectId = "<%= projectId %>";
            let isFirstLoad = true;
            const urlParams = new URLSearchParams(window.location.search);
            const viewParam = urlParams.get('view');
            let currentFolderId = urlParams.get('folder') || '';
            let currentFolderPath = []; // breadcrumb trail: [{_id, name}, ...]
            function getFileIcon(filename, extension) {
                // If it's a folder
                if (!filename || extension === 'folder' || extension === '') {
                    return '/img/icons/folder.png';
                }

                const ext = (extension || filename.split('.').pop() || '').toLowerCase();

                // Check if it's an image - return special marker for thumbnail
                if (imageExtensions.includes(ext)) {
                    return 'image';
                }

                // Check if extension exists in mapping
                return fileIcons[ext] || fileIcons['default'] || '/img/icons/file.png';
            }

            function openFolder(folderId, folderName) {
                if (!folderId) {
                    goToRoot();
                    return;
                }

                currentFolderId = folderId;

                // Update the URL without a full page reload
                const newUrl = `${window.location.pathname}?folder=${folderId}`;
                history.pushState({ folderId, folderName }, '', newUrl);

                // Reset to page 1 and refresh breadcrumb + table + stats
                paginationState.page = 1;
                loadBreadcrumb(folderId);
                loadData();
                loadFolderSummary();
            }
            window.openFolder = openFolder;

            function goToRoot() {
                currentFolderId = '';
                history.pushState({}, '', window.location.pathname);
                paginationState.page = 1;
                currentPath = [];
                loadBreadcrumb('');
                loadData();
                loadFolderSummary();
            }
            window.goToRoot = goToRoot;

            // Handle browser Back/Forward buttons
            window.addEventListener('popstate', function () {
                const params = new URLSearchParams(window.location.search);
                currentFolderId = params.get('folder') || '';
                paginationState.page = 1;
                loadBreadcrumb(currentFolderId);
                loadData();
                loadFolderSummary();
            });

            function navigateToBreadcrumb(index) {
                if (index < 0 || !currentPath[index]) {
                    goToRoot();
                    return;
                }

                const target = currentPath[index];
                openFolder(target.id, target.name);
            }
            // Get current path from breadcrumb data
            let currentPath = [];

            function getCurrentPath() {
                return currentPath;
            }

            async function handleViewListWithoutReload() {
                // Check if we have view=list in URL and projectId exists
                if (viewParam === 'list' && projectId && !currentFolderId) {
                    try {
                        // Show loading state on table only
                        $('#folder-loading').show();

                        // Fetch folders for this project (only folders, limit 1)
                        const response = await fetch(`/api/all-folder-files?projectId=${projectId}&limit=1&page=1&itemType=folder&sortBy=createdAt&sortOrder=asc`, {
                            credentials: "include",
                            cache: "no-store"
                        });

                        const result = await response.json();
                        console.log('First folder response:', result); // Debug log

                        if (result.success && result.items && result.items.length > 0) {
                            // Find the first folder (ensure it's a folder type)
                            const firstFolder = result.items.find(item => item.itemType === 'folder');

                            if (firstFolder) {
                                const firstFolderId = firstFolder._id;
                                const firstFolderName = firstFolder.name;

                                // Update URL without page reload
                                urlParams.delete('view');
                                urlParams.set('folder', firstFolderId);
                                const newUrl = `${window.location.pathname}?${urlParams.toString()}`;
                                window.history.pushState({
                                    folderId: firstFolderId,
                                    folderName: firstFolderName
                                }, '', newUrl);

                                // Update current folder
                                currentFolderId = firstFolderId;

                                // Load breadcrumb, table data, and summary
                                await loadBreadcrumb(firstFolderId);
                                await loadData(); // This reloads only the table
                                await loadFolderSummary();

                            } else {
                                // No folders found, just remove view param
                                urlParams.delete('view');
                                const newUrl = `${window.location.pathname}?${urlParams.toString()}`;
                                window.history.pushState({}, '', newUrl);
                                await loadData();
                                showToast('info', 'No folders found for this project');
                            }
                        } else {
                            // No items found
                            urlParams.delete('view');
                            const newUrl = `${window.location.pathname}?${urlParams.toString()}`;
                            window.history.pushState({}, '', newUrl);
                            await loadData();
                            showToast('info', 'No folders found for this project');
                        }
                    } catch (error) {
                        console.error('Error fetching first folder:', error);
                        // On error, remove view param and reload data
                        urlParams.delete('view');
                        const newUrl = `${window.location.pathname}?${urlParams.toString()}`;
                        window.history.pushState({}, '', newUrl);
                        await loadData();
                        showToast('error', 'Failed to load project folders');
                    } finally {
                        $('#folder-loading').hide();
                        isFirstLoad = false;
                    }
                } else {
                    isFirstLoad = false;
                }
            }
            async function loadBreadcrumb(folderId) {
                const container = $("#breadcrumb-list");

                if (!folderId) {
                    container.html(`
            <li class="breadcrumb-item active">
                <a href="#" return false;">
                    <i class="ti ti-home"></i> Home
                </a>
            </li>
        `);
                    currentPath = [];
                    return;
                }

                try {
                    const res = await fetch(`/api/folders/${folderId}/directory`, {
                        credentials: "include",
                        cache: "no-store"
                    });

                    const result = await res.json();

                    if (!result.success || !result.data?.hierarchy) {
                        throw new Error(result.message || "Failed to load breadcrumb");
                    }

                    const hierarchy = result.data.hierarchy;
                    currentPath = hierarchy;

                    let html = `
            <li class="breadcrumb-item">
                <a href="#"  return false;">
                    <i class="ti ti-home"></i> Home
                </a>
            </li>
        `;

                    hierarchy.forEach((part, index) => {
                        const isLast = index === hierarchy.length - 1;

                        if (isLast) {
                            html += `
                    <li class="breadcrumb-item active" aria-current="page">
                        <span>${escapeHtml(part.name)}</span>
                    </li>
                `;
                        } else {
                            html += `
                    <li class="breadcrumb-item">
                        <a href="#" onclick="navigateToBreadcrumb(${index}); return false;">
                            ${escapeHtml(part.name)}
                        </a>
                    </li>
                `;
                        }
                    });

                    container.html(html);

                } catch (err) {
                    console.error("Breadcrumb load failed:", err);
                    container.html(`
            <li class="breadcrumb-item">
                <a href="#" return false;">
                    <i class="ti ti-home"></i> Home
                </a>
            </li>
            <li class="breadcrumb-item active">
                <span>Current Folder</span>
            </li>
        `);
                }
            }
            function renderFileIcon(item) {
                const isFolder = item.itemType === 'folder';
                const ext = (item.extension || '').toLowerCase();
                const isImage = imageExtensions.includes(ext);

                if (isFolder) {
                    return `
            <div class="file-thumbnail-wrapper"
                 style="cursor:pointer; width: 52px; height: 52px;"
                 onclick="openFolder('${item._id}', '${escapeHtml(item.displayName || item.name).replace(/'/g, "\\'")}')">
                <img src="/img/icons/folder.png"
                     alt="folder"
                     class="icon-only"
                     style="width:44px;height:44px;object-fit:contain;">
            </div>
        `;
                }

                // Check if it's an image and has S3 URL
                if (isImage && item.s3Url) {
                    return `
            <div class="file-thumbnail-wrapper"
                 style="cursor:pointer; width: 52px; height: 52px;"
                 onclick="previewFile('${item._id}')">
                <img src="${escapeHtml(item.s3Url)}"
                     alt="${escapeHtml(item.name)}"
                     class="image-thumbnail"
                     loading="lazy"
                     style="width:52px;height:52px;object-fit:cover;border-radius:4px;">
            </div>
        `;
                }

                // For non-image files, use the icon mapping
                const iconPath = fileIcons[ext] || fileIcons['default'] || '/img/icons/file.png';
                return `
        <div class="file-thumbnail-wrapper" 
             onclick="previewFile('${item._id}')"  
             style="cursor:pointer; width: 52px; height: 52px;">
            <img src="${iconPath}" 
                 alt="${ext || 'file'}" 
                 class="icon-only" 
                 style="width:40px;height:40px;object-fit:contain;"
                 onerror="this.src='/img/icons/file.png'">
        </div>
    `;
            }


            function goToParentFolder() {
                if (!currentFolderId) {
                    return;
                }

                const path = getCurrentPath();
                if (path.length > 1) {
                    const parentIndex = path.length - 2;
                    const parent = path[parentIndex];
                    if (parent && parent.id) {
                        openFolder(parent.id, parent.name);
                    } else {
                        goToRoot();
                    }
                } else {
                    goToRoot();
                }
            }

