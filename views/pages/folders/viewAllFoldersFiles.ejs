<script>
// Image extensions
const imageExtensions = ['jpg', 'jpeg', 'png', 'gif', 'svg', 'webp', 'bmp', 'ico'];

function getFileIcon(filename, extension) {
    // If it's a folder
    if (!filename || extension === 'folder' || extension === '') {
        return '/img/icons/folder.png';
    }
    
    const ext = (extension || filename.split('.').pop() || '').toLowerCase();
    
    // Check if it's an image - return special marker for thumbnail
    if (imageExtensions.includes(ext)) {
        return 'image';
    }
    
    // Check if extension exists in mapping
    return fileIcons[ext] || fileIcons['default'] || '/img/icons/file.png';
}

// Updated renderFileIcon function with better sizing
function renderFileIcon(item) {
    const isFolder = item.itemType === 'folder';
    const ext = (item.extension || '').toLowerCase();
    const isImage = imageExtensions.includes(ext);
    
    if (isFolder) {
        return `
            <div class="file-thumbnail-wrapper">
                <img src="/img/icons/folder.png" alt="folder" class="icon-only" 
                     style="width:44px;height:44px;object-fit:contain;"
                     onerror="this.src='/img/icons/folder.png'">
            </div>
        `;
    }
    
    // Check if it's an image and has S3 URL
    if (isImage && item.s3Url) {
        return `
            <div class="file-thumbnail-wrapper">
                <img src="${escapeHtml(item.s3Url)}" alt="${escapeHtml(item.name)}" 
                     class="image-thumbnail" 
                     loading="lazy"
                     style="width:52px;height:52px;object-fit:cover;border-radius:4px;"
                     onerror="this.parentElement.innerHTML='<img src=\\'/img/icons/image.png\\' class=\\'icon-only\\' style=\\'width:40px;height:40px;object-fit:contain;\\'>'">
            </div>
        `;
    }
    
    // For non-image files, use the icon mapping
    const iconPath = fileIcons[ext] || fileIcons['default'] || '/img/icons/file.png';
    return `
        <div class="file-thumbnail-wrapper">
            <img src="${iconPath}" alt="${ext || 'file'}" class="icon-only" 
                 style="width:40px;height:40px;object-fit:contain;"
                 onerror="this.src='/img/icons/file.png'">
        </div>
    `;
}

// ============================================
// PAGINATION STATE
// ============================================
let paginationState = {
    page: 1,
    limit: 100,
    total: 0,
    totalPages: 1,
    items: []
};

let isLoading = false;

// ============================================
// DOCUMENT READY
// ============================================
$(document).ready(function () {
    // Initialize Department Select2
    $('#departmentFilter').select2({
        placeholder: '-- Select Department --',
        allowClear: true,
        width: '100%',
        ajax: {
            url: '/api/departments/search',
            dataType: 'json',
            delay: 250,
            data: function (params) {
                return { search: params.term || '' };
            },
            processResults: function (data) {
                const results = [
                    { id: '', text: 'All Departments' },
                    ...(data.data || []).map(item => ({
                        id: item._id,
                        text: item.name
                    }))
                ];
                return { results: results };
            },
            cache: true
        }
    });

    // Load initial data
    loadFolderSummary();
    loadData();

    // Event listeners
    let filterTimeout;

    $("#departmentFilter").on("change", function () {
        clearTimeout(filterTimeout);
        filterTimeout = setTimeout(() => {
            paginationState.page = 1;
            loadData();
            loadFolderSummary();
        }, 300);
    });

    $("#SearchFolderInput").on("input", function () {
        clearTimeout(filterTimeout);
        filterTimeout = setTimeout(() => {
            paginationState.page = 1;
            loadData();
        }, 500);
    });

    $("#recentActivitySort").on("change", function () {
        paginationState.page = 1;
        loadData();
    });

    $(".view-folder").on("click", function(e) {
        e.preventDefault();
        $(".view-folder").removeClass("active");
        $(this).addClass("active");
        paginationState.page = 1;
        loadData();
    });

    // Per page change handler
    $("#perPageSelect").on("change", function() {
        paginationState.limit = parseInt($(this).val());
        paginationState.page = 1;
        loadData();
    });

    // Pagination button handlers
    $("#firstPageBtn").on("click", function() {
        if (paginationState.page > 1) {
            paginationState.page = 1;
            loadData();
        }
    });

    $("#prevPageBtn").on("click", function() {
        if (paginationState.page > 1) {
            paginationState.page--;
            loadData();
        }
    });

    $("#nextPageBtn").on("click", function() {
        if (paginationState.page < paginationState.totalPages) {
            paginationState.page++;
            loadData();
        }
    });

    $("#lastPageBtn").on("click", function() {
        if (paginationState.page < paginationState.totalPages) {
            paginationState.page = paginationState.totalPages;
            loadData();
        }
    });

    // Select all checkbox
    $(".select-all-folder").on("change", function() {
        $(".select-folder").prop("checked", $(this).prop("checked"));
    });

    // Clear filters
    $("#clearFilters").on("click", function(e) {
        e.preventDefault();
        clearAllFilters();
    });
});

// ============================================
// MAIN DATA LOAD FUNCTION
// ============================================
async function loadData() {
    if (isLoading) return;
    isLoading = true;

    try {
        const tbody = $("#recycleTable tbody");
        tbody.html(`
            <tr>
                <td colspan="8" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2 text-muted">Loading items...</p>
                </td>
            </tr>
        `);

        // Build query parameters
        const departmentId = $("#departmentFilter").val() || "";
        const search = $("#SearchFolderInput").val() || "";
        const sortBy = $("#recentActivitySort").val() || "updatedAt_desc";
        const viewFilter = $(".view-folder.active").data("filter") || null;

        let sortField = 'updatedAt';
        let sortOrder = 'desc';
        if (sortBy) {
            const parts = sortBy.split('_');
            if (parts.length === 2) {
                sortField = parts[0];
                sortOrder = parts[1] === 'asc' ? 'asc' : 'desc';
            }
        }

        const params = new URLSearchParams({
            department: departmentId || '',
            search: search || '',
            sortBy: sortField,
            sortOrder: sortOrder,
            itemType: 'all',
            page: paginationState.page,
            limit: paginationState.limit
        });

        if (viewFilter) {
            params.append('viewFilter', viewFilter);
        }

        const url = `/api/all-folder-files?${params.toString()}`;
        const response = await fetch(url, { 
            credentials: "include", 
            cache: "no-store" 
        });
        
        const result = await response.json();

        if (!result.success) {
            throw new Error(result.message || 'Failed to load items');
        }

        // Update pagination state
        paginationState.total = result.total || 0;
        paginationState.totalPages = result.totalPages || 1;
        paginationState.page = result.page || 1;
        paginationState.items = result.items || [];

        if (paginationState.items.length > 0) {
            renderTableRows(paginationState.items);
        } else {
            renderEmptyState();
        }

        updatePaginationUI();

    } catch (err) {
        console.error("Failed to load data:", err);
        $("#recycleTable tbody").html(`
            <tr>
                <td colspan="8" class="text-center py-4">
                    <i class="ti ti-alert-circle text-danger fs-3"></i>
                    <p class="mt-2 text-danger">${escapeHtml(err.message || 'Failed to load items. Please try again.')}</p>
                    <button class="btn btn-outline-primary btn-sm mt-2" onclick="loadData()">
                        <i class="ti ti-refresh"></i> Retry
                    </button>
                </td>
            </tr>
        `);
        updatePaginationUI();
    } finally {
        isLoading = false;
    }
}

// ============================================
// RENDER FUNCTIONS
// ============================================

function renderTableRows(items) {
    const tbody = $("#recycleTable tbody");
    
    if (!items || items.length === 0) {
        renderEmptyState();
        return;
    }

    let html = '';
    items.forEach(item => {
        const isFolder = item.itemType === 'folder';
        const ext = (item.extension || '').toLowerCase();
        const isImage = imageExtensions.includes(ext);
        
        // Render file icon
        const iconHtml = renderFileIcon(item);
        
        // Type badge
        let typeBadge;
        if (isFolder) {
            typeBadge = `<span class="badge bg-soft-primary text-primary">${item.typeBadge || 'Folder'}</span>`;
        } else if (isImage) {
            typeBadge = `<span class="badge bg-soft-success text-success">Image</span>`;
        } else {
            typeBadge = `<span class="badge bg-light">${item.typeBadge || (ext || 'File').toUpperCase()}</span>`;
        }
        
        // Name display
        let nameDisplay;
        if (isFolder) {
            nameDisplay = `
                <p class="fs-14 mb-1 fw-normal">${escapeHtml(item.displayName || item.name)}</p>
                <span class="fs-11 fw-light text-black">${item.itemCount || 0} Items</span>
            `;
        } else {
            nameDisplay = `
                <p class="fs-14 mb-1 fw-normal">${escapeHtml(item.displayName || item.name)}</p>
                <span class="badge bg-soft-primary fs-11">${(ext || 'file').toUpperCase()}</span>
            `;
        }

        const sharedIcon = item.isShared ? ' <i class="ti ti-share text-primary" title="Shared"></i>' : '';

        html += `
            <tr>
                <td>
                    <div class="form-check form-check-md">
                        <input class="form-check-input select-folder" type="checkbox" data-folder-id="${item._id}" data-type="${item.itemType}">
                    </div>
                </td>
                <td>
                    <div class="flxtblleft d-flex align-items-center">
                        ${iconHtml}
                        <div class="flxtbltxt">
                            ${nameDisplay}
                            ${sharedIcon}
                        </div>
                    </div>
                </td>
                <td>
                    <div class="flxtblleft d-flex align-items-center">
                        <span class="avatar rounded-5 bg-soft-primary fs-12 text-info nameinitials" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                            ${item.ownerInitials || '??'}
                        </span>
                        <div class="flxtbltxt ms-2">
                            <p class="fs-14 fw-normal mb-0">${escapeHtml(item.ownerName || 'Unknown')}</p>
                        </div>
                    </div>
                </td>
                <td>${escapeHtml(item.department || 'N/A')}</td>
                <td>${typeBadge}</td>
                <td>${isFolder ? '-' : escapeHtml(item.size || '0 KB')}</td>
                <td>${escapeHtml(item.modified || 'N/A')}</td>
                <td>
                    <div class="docsaction">
                        <button type="button" class="btn border-0" data-bs-toggle="dropdown">
                            <i class="ti ti-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu">
                            ${isFolder ? `
                                <li><a class="dropdown-item" href="/folders/${item._id}">
                                    <i class="ti ti-folder-open"></i> Open
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="editFolder('${item._id}')">
                                    <i class="ti ti-edit"></i> Edit
                                </a></li>
                                ${item.isShared ? `
                                    <li><a class="dropdown-item" href="#" onclick="managePermissions('${item._id}')">
                                        <i class="ti ti-lock"></i> Permissions
                                    </a></li>
                                ` : ''}
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#" onclick="deleteItem('${item._id}', 'folder')">
                                    <i class="ti ti-trash"></i> Delete
                                </a></li>
                            ` : `
                                <li><a class="dropdown-item" href="#" onclick="previewFile('${item._id}')">
                                    <i class="ti ti-eye"></i> Preview
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="downloadFile('${item._id}')">
                                    <i class="ti ti-download"></i> Download
                                </a></li>
                                ${item.isShared ? `
                                    <li><a class="dropdown-item" href="#" onclick="shareFile('${item._id}')">
                                        <i class="ti ti-share"></i> Share
                                    </a></li>
                                ` : ''}
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#" onclick="deleteItem('${item._id}', 'file')">
                                    <i class="ti ti-trash"></i> Delete
                                </a></li>
                            `}
                        </ul>
                    </div>
                </td>
            </tr>
        `;
    });

    tbody.html(html);
}

function renderEmptyState() {
    $("#recycleTable tbody").html(`
        <tr>
            <td colspan="8" class="text-center py-5">
                <i class="ti ti-folder-off fs-2 text-muted"></i>
                <p class="mt-2 text-muted">No items found matching your criteria</p>
                <button class="btn btn-outline-primary btn-sm mt-2" onclick="clearAllFilters()">
                    <i class="ti ti-refresh"></i> Clear Filters
                </button>
            </td>
        </tr>
    `);
}

// ============================================
// PAGINATION UI
// ============================================

function updatePaginationUI() {
    const { page, totalPages, total, limit } = paginationState;
    
    // Update info text
    const start = total === 0 ? 0 : (page - 1) * limit + 1;
    const end = Math.min(start + limit - 1, total);
    $("#paginationInfo").text(
        total === 0 ? 'No items found' : `Showing ${start}-${end} of ${total} items`
    );

    // Update page buttons
    const pageNumbersContainer = $("#pageNumbers");
    let pageHtml = '';

    if (totalPages > 0) {
        const maxVisible = 5;
        let startPage = Math.max(1, page - Math.floor(maxVisible / 2));
        let endPage = Math.min(totalPages, startPage + maxVisible - 1);
        
        if (endPage - startPage + 1 < maxVisible) {
            startPage = Math.max(1, endPage - maxVisible + 1);
        }

        if (startPage > 1) {
            pageHtml += `<button class="page-btn" data-page="1">1</button>`;
            if (startPage > 2) {
                pageHtml += `<span class="page-btn disabled">...</span>`;
            }
        }

        for (let i = startPage; i <= endPage; i++) {
            pageHtml += `<button class="page-btn ${i === page ? 'active' : ''}" data-page="${i}">${i}</button>`;
        }

        if (endPage < totalPages) {
            if (endPage < totalPages - 1) {
                pageHtml += `<span class="page-btn disabled">...</span>`;
            }
            pageHtml += `<button class="page-btn" data-page="${totalPages}">${totalPages}</button>`;
        }
    }

    pageNumbersContainer.html(pageHtml);

    // Attach click events to page buttons
    $(".page-btn[data-page]").off("click").on("click", function(e) {
        e.preventDefault();
        const targetPage = parseInt($(this).data("page"));
        if (targetPage && targetPage !== paginationState.page) {
            paginationState.page = targetPage;
            loadData();
            // Scroll to table top
            $(".custom-datatable-filter").closest(".card").get(0)?.scrollIntoView({ 
                behavior: 'smooth', 
                block: 'start' 
            });
        }
    });

    // Update navigation buttons
    $("#firstPageBtn").toggleClass("disabled", page <= 1);
    $("#prevPageBtn").toggleClass("disabled", page <= 1);
    $("#nextPageBtn").toggleClass("disabled", page >= totalPages);
    $("#lastPageBtn").toggleClass("disabled", page >= totalPages);
}

// ============================================
// DASHBOARD SUMMARY
// ============================================

async function loadFolderSummary() {
    try {
        const departmentId = $("#departmentFilter").val() || "";
        const url = `/api/folders/summary?departmentId=${departmentId}`;

        const response = await fetch(url, { credentials: "include", cache: "no-store" });
        const result = await response.json();

        if (!result.success) {
            console.warn('Summary API failed:', result.message);
            return;
        }

        const summary = result.data || {};

        $("#totalDocs").text(summary.totalFolders ?? 0);
        $("#approvedDocs").text(summary.totalFiles ?? 0);
        
        if (summary.storage) {
            $("#pendingDocs").text(`${summary.storage.value} ${summary.storage.unit}`);
        }
        
        if (summary.storageLimit) {
            $("#storageLimit").text(`of ${summary.storageLimit} GB`);
        }
        
        $("#rejectedDocs").text(summary.permissions ?? 0);

    } catch (err) {
        console.error("Failed to load dashboard summary:", err);
    }
}

// ============================================
// HELPER FUNCTIONS
// ============================================

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// ============================================
// ACTION FUNCTIONS
// ============================================

function editFolder(id) {
    console.log('Edit folder:', id);
    showToast('info', 'Edit folder functionality coming soon');
}

function previewFile(id) {
    console.log('Preview file:', id);
    window.open(`/api/files/${id}/view`, '_blank');
}

function downloadFile(id) {
    console.log('Download file:', id);
    window.location.href = `/api/files/${id}/download`;
}

function viewFile(id) {
    console.log('View file:', id);
    window.open(`/api/files/${id}/view`, '_blank');
}

function shareFile(id) {
    console.log('Share file:', id);
    showToast('info', 'Share functionality coming soon');
}

function managePermissions(id) {
    console.log('Manage permissions:', id);
    showToast('info', 'Permissions management coming soon');
}

function deleteItem(id, type) {
    if (confirm(`Are you sure you want to delete this ${type}?`)) {
        console.log('Delete:', id, type);
        // Add actual delete API call here
        loadData();
        loadFolderSummary();
        showToast('success', `${type} deleted successfully`);
    }
}

function clearAllFilters() {
    $("#departmentFilter").val('').trigger('change');
    $("#SearchFolderInput").val('');
    $("#recentActivitySort").val('updatedAt_desc').trigger('change');
    $(".view-folder").removeClass('active');
    $(".view-folder[data-filter='lastModified']").addClass('active');
    paginationState.page = 1;
    loadData();
}

function refreshData() {
    paginationState.page = 1;
    loadData();
    loadFolderSummary();
    showToast('success', 'Data refreshed successfully');
}

function showToast(type, message) {
    const toast = $(`
        <div class="toast align-items-center text-white bg-${type} border-0 show" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999;">
            <div class="d-flex">
                <div class="toast-body">${message}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    `);
    $('body').append(toast);
    setTimeout(() => toast.remove(), 5000);
}

// Expose functions globally
window.editFolder = editFolder;
window.previewFile = previewFile;
window.downloadFile = downloadFile;
window.viewFile = viewFile;
window.shareFile = shareFile;
window.managePermissions = managePermissions;
window.deleteItem = deleteItem;
window.clearAllFilters = clearAllFilters;
window.loadData = loadData;
window.loadFolderSummary = loadFolderSummary;
window.refreshData = refreshData;
window.showToast = showToast;
window.fileIcons = fileIcons;
window.imageExtensions = imageExtensions;
window.renderFileIcon = renderFileIcon;
window.paginationState = paginationState;
</script>