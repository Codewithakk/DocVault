<style>
    .folderbox.blocked {
        cursor: not-allowed;
        opacity: 0.5;
    }

    .folderbox.blocked-user {
        cursor: not-allowed !important;
    }

    .breadcrumb {
        font-size: 15px;
    }

    .breadcrumb-item,
    .breadcrumb-link {
        font-size: 15px;
    }

    .breadcrumb-item i {
        font-size: 15px;
    }

    .folderbox.blocked-user img {
        filter: grayscale(100%) brightness(60%);
    }

    .folderbox.blocked-owner img {
        filter: brightness(70%) saturate(80%);
    }

    .disabled-link {
        pointer-events: none;
        opacity: 0.5;
    }

    #folder-container {
        display: flex;
        flex-wrap: wrap;
