        margin-bottom: 5px;
    }

    .fldrname p {
        margin-bottom: 5px;
        max-width: 200px;
        color: #333;
        font-weight: 500;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .folder_links {
        position: absolute;
