<%- include('../../partials/header') %>

    <style>
        .folderbox.blocked {
            cursor: not-allowed;
            opacity: 0.5;
        }

        .folderbox.blocked-user {
            cursor: not-allowed !important;
        }

        .breadcrumb {
            font-size: 15px;
        }

        .breadcrumb-item,
        .breadcrumb-link {
            font-size: 15px;
        }

        .breadcrumb-item i {
            font-size: 15px;
        }

        .folderbox.blocked-user img {
            filter: grayscale(100%) brightness(60%);
        }

        .folderbox.blocked-owner img {
            filter: brightness(70%) saturate(80%);
        }

        .disabled-link {
            pointer-events: none;
            opacity: 0.5;
        }

        #folder-container {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            align-items: flex-start;
        }

        .folderbox {
            flex: 0 0 23.5%;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            padding: 20px;
            border: 1px solid #eee;
            transition: all 0.2s ease-in-out;
            cursor: pointer;
            position: relative;
        }

        .folderbox:hover {
            background-color: #f8f8f8;
            border-color: #c9c9c9;
        }

        .fldricon {
            margin-bottom: 5px;
            width: 64px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .fldricon img {
            max-width: 100%;
            height: auto;
        }

        .fldrname {
            width: 100%;
            margin-bottom: 5px;
        }

        .fldrname p {
            margin-bottom: 5px;
            max-width: 200px;
            color: #333;
            font-weight: 500;
            overflow: hidden;
            white-space: nowrap;
            text-overflow: ellipsis;
        }

        .folder_links {
            position: absolute;
            top: 10px;
            right: 10px;
        }

        .folder_links .btn {
            padding: 0;
            line-height: 1;
        }

        /* Image thumbnail styles */
        .file-thumbnail {
            width: 40px;
            height: 40px;
            border-radius: 4px;
            object-fit: cover;
            background-color: #f8f9fa;
        }

        .file-thumbnail-icon {
            width: 32px;
            height: 32px;
            object-fit: contain;
        }

        .avatar-icon-wrapper {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f8f9fa;
            border-radius: 4px;
            overflow: hidden;
        }

        .avatar-icon-wrapper img {
            max-width: 100%;
            max-height: 100%;
            object-fit: cover;
        }

        .avatar-icon-wrapper img.icon-only {
            object-fit: contain;
            width: 32px;
            height: 32px;
        }

        @media (max-width: 1400px) {
            .folderbox {
                flex: 0 0 31.5%;
            }
        }


        @media (max-width: 992px) {
            .folderbox {
                flex: 0 0 32%;
            }
        }

        @media (max-width: 768px) {
            .folderbox {
                flex: 0 0 49%;
            }
        }

        @media (max-width: 576px) {
            .folderbox {
                flex: 0 0 100%;
            }
        }

        /* Active stats card */
        .dashboard-card.active-stats-card {
            border: 2px solid #0d6efd;
            box-shadow: 0 0 10px rgba(13, 110, 253, 0.2);
        }

        .file-thumbnail-wrapper {
            width: 48px;
            height: 48px;
            min-width: 48px;
            min-height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f8f9fa;
            border-radius: 6px;
            overflow: hidden;
            flex-shrink: 0;
        }

        .file-thumbnail-wrapper .icon-only {
            width: 40px;
            height: 40px;
            object-fit: contain;
            display: block;
        }

        .file-thumbnail-wrapper .image-thumbnail {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        /* Increase folder icon size in table */
        .flxtblleft .file-thumbnail-wrapper {
            width: 52px;
            height: 52px;
            min-width: 52px;
            min-height: 52px;
        }

        .flxtblleft .file-thumbnail-wrapper .icon-only {
            width: 44px;
            height: 44px;
        }

        /* Fix text alignment in table rows */
        .flxtblleft {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .flxtbltxt {
            min-width: 0;
            flex: 1;
        }

        .flxtbltxt p {
            margin-bottom: 2px;
            line-height: 1.3;
        }

        /* Make avatar initials larger */
        .nameinitials {
            width: 36px !important;
            height: 36px !important;
            min-width: 36px;
            min-height: 36px;
            font-size: 14px !important;
            font-weight: 600;
        }

        /* Fix the folder container icons (grid view) */
        .fldricon {
            width: 80px;
            height: 80px;
            margin: 0 auto 10px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .fldricon img {
            width: 72px;
            height: 72px;
            object-fit: contain;
            display: block;
        }

        /* Adjust folderbox for better icon display */
        .folderbox {
            flex: 0 0 23.5%;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 25px 20px;
            border: 1px solid #eee;
            transition: all 0.2s ease-in-out;
            cursor: pointer;
            position: relative;
            border-radius: 8px;
        }

        .folderbox .fldrname p {
            font-size: 15px;
            font-weight: 500;
            margin-bottom: 4px;
            max-width: 100%;
            overflow: hidden;
            white-space: nowrap;
            text-overflow: ellipsis;
        }

        .folderbox .fldrname small {
            font-size: 12px;
            color: #888;
        }

        /* DataTable custom styles */
        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_processing,
        .dataTables_wrapper .dataTables_paginate {
            display: none !important;
        }

        .dataTables_wrapper .dataTable {
            margin-bottom: 0 !important;
        }

        .dataTables_wrapper .dataTable thead th {
            background-color: #f8f9fa;
            border-bottom: 2px solid #dee2e6;
            padding: 12px 10px;
            font-weight: 600;
            font-size: 13px;
            color: #495057;
        }

        .dataTables_wrapper .dataTable tbody td {
            padding: 10px;
            vertical-align: middle;
            border-bottom: 1px solid #f0f0f0;
        }

        .dataTables_wrapper .dataTable tbody tr:hover {
            background-color: #f8f9fa;
        }

        /* Custom pagination styles */
        .custom-pagination {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px 0 5px 0;
            border-top: 1px solid #e9ecef;
            margin-top: 15px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .custom-pagination .pagination-info {
            font-size: 14px;
            color: #6c757d;
        }

        .custom-pagination .pagination-controls {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .custom-pagination .page-btn {
            border: 1px solid #dee2e6;
            background: #fff;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            color: #333;
            transition: all 0.2s;
            min-width: 36px;
            text-align: center;
        }

        .custom-pagination .page-btn:hover:not(.disabled):not(.active) {
            background: #e9ecef;
            border-color: #ced4da;
        }

        .custom-pagination .page-btn.active {
            background: #0d6efd;
            color: #fff;
            border-color: #0d6efd;
        }

        .custom-pagination .page-btn.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }

        .custom-pagination .page-btn i {
            font-size: 12px;
        }

        .custom-pagination .per-page-select {
            padding: 4px 8px;
            border: 1px solid #dee2e6;
            border-radius: 4px;
            font-size: 14px;
            background: #fff;
            cursor: pointer;
            margin-left: 10px;
        }

        .custom-pagination .per-page-select:focus {
            outline: none;
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
        }

        @media (max-width: 768px) {
            .custom-pagination {
                flex-direction: column;
                align-items: stretch;
                gap: 15px;
            }

            .custom-pagination .pagination-controls {
                justify-content: center;
                flex-wrap: wrap;
            }
        }

        /* Responsive adjustments */
        @media (max-width: 1400px) {
            .folderbox {
                flex: 0 0 31.5%;
            }
        }

        @media (max-width: 992px) {
            .folderbox {
                flex: 0 0 32%;
            }
        }

        @media (max-width: 768px) {
            .folderbox {
                flex: 0 0 49%;
            }
        }

        @media (max-width: 576px) {
            .folderbox {
                flex: 0 0 100%;
            }
        }
    </style>

