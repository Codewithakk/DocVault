<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>File Preview</title>
    
    <!-- Disable Text Selection -->
    <style>
        html,
        body {
            margin: 0;
            padding: 0;
            height: 100%;
            user-select: none;
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
        }

        iframe,
        img {
            display: block;
            width: 100%;
            height: 100%;
            border: none;
        }

        img {
            object-fit: contain;
            /* Disable dragging for images */
            -webkit-user-drag: none;
            -khtml-user-drag: none;
            -moz-user-drag: none;
            -o-user-drag: none;
            user-drag: none;
        }

        /* Prevent selection of any content */
        * {
            -webkit-touch-callout: none;
            -webkit-user-select: none;
            -khtml-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
        }
    </style>
</head>

<!-- 1. Disable Right Click -->
<body oncontextmenu="return false;">

    <% if (!file) { %>
        <p style="text-align:center; padding:20px;">File not found.</p>
    <% } else { %>

        <% if (file.fileType.isPDF) { %>
            <!-- PDF Viewer -->
            <iframe src="/api/file/pdf/<%= file._id %>"></iframe>

        <% } else if (['png','jpg','jpeg','gif'].includes(file.fileType.extension)) { %>
            <!-- Image Preview with draggable disabled -->
            <img src="<%= file.fileUrl %>" alt="<%= file.originalName %>" draggable="false" />

        <% } else if (file.fileType.isWord || file.fileType.isExcel || file.fileType.isPowerPoint) { %>
            <!-- Office Preview -->
            <iframe
                src="https://view.officeapps.live.com/op/embed.aspx?src=<%= encodeURIComponent(file.fileUrl) %>"></iframe>

        <% } else { %>
            <!-- Other file types -->
            <p style="text-align:center; padding:20px;">
                Download file:
                <a href="/api/download/file/<%= file._id %>" target="_blank">Click here</a>
            </p>
        <% } %>

    <% } %>

    <script>
        // 2. Disable Common Keyboard Shortcuts
        document.addEventListener("keydown", function(e) {
            // Block PrintScreen key
            if (e.key === "PrintScreen") {
                e.preventDefault();
                return false;
            }

            // Block Ctrl+ combinations
            if (e.ctrlKey) {
                const key = e.key.toLowerCase();
                // Block Ctrl+S (Save), Ctrl+P (Print), Ctrl+U (View Source), Ctrl+C (Copy)
                if (["s", "p", "u", "c"].includes(key)) {
                    e.preventDefault();
                    return false;
                }

                // Block Ctrl+Shift+ combinations
                if (e.shiftKey && ["i", "j", "c"].includes(key)) {
                    e.preventDefault();
                    return false;
                }

                // Block Ctrl+Shift+I (DevTools), Ctrl+Shift+J (Console), Ctrl+Shift+C (Inspect)
                if (e.shiftKey && key === "i") {
                    e.preventDefault();
                    return false;
                }
            }

            // Block F12 key
            if (e.key === "F12") {
                e.preventDefault();
                return false;
            }

            // Block Ctrl+Shift+Delete (Clear browsing data)
            if (e.ctrlKey && e.shiftKey && e.key === "Delete") {
                e.preventDefault();
                return false;
            }
        });

        // Additional protection: Block right-click via event listener
        document.addEventListener("contextmenu", function(e) {
            e.preventDefault();
            return false;
        });

        // Block Ctrl+click (open in new tab)
        document.addEventListener("click", function(e) {
            if (e.ctrlKey || e.metaKey) {
                e.preventDefault();
                return false;
            }
        });

        // Block middle-click (open in new tab)
        document.addEventListener("mousedown", function(e) {
            if (e.button === 1) { // Middle button
                e.preventDefault();
                return false;
            }
        });

        // Prevent drag and drop of content
        document.addEventListener("dragstart", function(e) {
            e.preventDefault();
            return false;
        });

        // Prevent copy, cut, paste
        document.addEventListener("copy", function(e) {
            e.preventDefault();
            return false;
        });

        document.addEventListener("cut", function(e) {
            e.preventDefault();
            return false;
        });

        document.addEventListener("paste", function(e) {
            e.preventDefault();
            return false;
        });

        // Block keyboard shortcuts for DevTools (Mac)
        document.addEventListener("keydown", function(e) {
            // Cmd+Option+I (Mac DevTools)
            if (e.metaKey && e.altKey && e.key === "i") {
                e.preventDefault();
                return false;
            }
            // Cmd+Option+J (Mac Console)
            if (e.metaKey && e.altKey && e.key === "j") {
                e.preventDefault();
                return false;
            }
            // Cmd+Option+C (Mac Inspect)
            if (e.metaKey && e.altKey && e.key === "c") {
                e.preventDefault();
                return false;
            }
        });
    </script>

</body>

</html>