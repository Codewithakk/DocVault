<%- include('../../partials/header') %>

	<style>
		.folderbox.blocked {
			cursor: not-allowed;
			opacity: 0.5;
		}

		.folderbox.blocked-user {
			cursor: not-allowed !important;
		}

		.breadcrumb {
			font-size: 15px;
		}

		.breadcrumb-item,
		.breadcrumb-link {
			font-size: 15px;
		}

		.breadcrumb-item i {
			font-size: 15px;
		}

		.folderbox.blocked-user img {
			filter: grayscale(100%) brightness(60%);
		}

		.folderbox.blocked-owner img {
			filter: brightness(70%) saturate(80%);
		}

		.disabled-link {
			pointer-events: none;
			opacity: 0.5;
		}

		#folder-container {
			display: flex;
			flex-wrap: wrap;
			gap: 20px;
			align-items: flex-start;
		}

		.folderbox {
			flex: 0 0 23.5%;
			box-sizing: border-box;
			display: flex;
			flex-direction: column;
			padding: 20px;
			border: 1px solid #eee;
			transition: all 0.2s ease-in-out;
			cursor: pointer;
			position: relative;
		}

		.folderbox:hover {
			background-color: #f8f8f8;
			border-color: #c9c9c9;
		}

		.fldricon {
			margin-bottom: 5px;
			width: 64px;
			display: flex;
			justify-content: center;
			align-items: center;
		}

		.fldricon img {
			max-width: 100%;
			height: auto;
		}

		.fldrname {
			width: 100%;
			margin-bottom: 5px;
		}

		.fldrname p {
			margin-bottom: 5px;
			max-width: 200px;
			color: #333;
			font-weight: 500;
			overflow: hidden;
			white-space: nowrap;
			text-overflow: ellipsis;
		}

		.folder_links {
			position: absolute;
			top: 10px;
			right: 10px;
		}

		.folder_links .btn {
			padding: 0;
			line-height: 1;
		}

		@media (max-width: 1400px) {
			.folderbox {
				flex: 0 0 31.5%;
			}
		}


		@media (max-width: 992px) {
			.folderbox {
				flex: 0 0 32%;
			}
		}

		@media (max-width: 768px) {
			.folderbox {
				flex: 0 0 49%;
			}
		}

		@media (max-width: 576px) {
			.folderbox {
				flex: 0 0 100%;
			}
		}

		/* Active stats card */
		.dashboard-card.active-stats-card {
			border: 2px solid #0d6efd;
			box-shadow: 0 0 10px rgba(13, 110, 253, 0.2);
		}
	</style>
	<div class="page-wrapper">
		<div class="content">

			<div class="d-flex align-items-center justify-content-between page-breadcrumb mb-3">
				<div class="my-auto mb-2">
					<h2 class="mb-1">Folders</h2>
					<nav>
						<ol class="breadcrumb mb-0" id="breadcrumb-list">
						</ol>
					</nav>
				</div>
				<div class="rtbtn">
					<% if (profile_type !=='vendor' && profile_type !=='donor' ) { %>
						<a href="#" class="btn btn-primary btn-lg rounded-3 me-2 mb-2 btn-add-folder" id="btnAddFolder">
							<i class="ti ti-plus me-1"></i> Create Folder
						</a>
						<% } %>
				</div>
			</div>


			<div class="row py-4">
				<div class="col-xxl-12">
					<div class="row flex-fill">
						<div class="col-md-3 d-flex">
							<div class="card flex-fill dashboard-card dashboardtop-card" data-show="Total"
								style="cursor: pointer;">
								<div class="card-body">
									<div class="card_avtr_right">
										<span class="avatar avatar-xxl text-info rounded-4 bg-soft-primary mb-2">
											<i class="ti ti-folder fs-40"></i>
										</span>
									</div>
									<div class="dashcrd_txt">
										<h3 class="fs-32 fw-medium mb-2" id="totalDocs">18</h3>
										<h6 class="fs-16 fw-medium text-dark mb-1">Total Folders</h6>
										<span class="fs-12 fw-medium text-success">
											<i class="ti ti-trending-up"></i> 12% <span class="text-dark">from last
												month</span>
										</span>
									</div>
								</div>
							</div>
						</div>
						<div class="col-md-3 d-flex">
							<div class="card flex-fill dashboard-card dashboardtop-card" data-show="Shared"
								style="cursor: pointer;">
								<div class="card-body">
									<div class="card_avtr_right">
										<span class="avatar avatar-xxl text-green rounded-4 bg-soft-success mb-2">
											<i class="ti ti-folder-plus fs-40"></i>
										</span>
									</div>
									<div class="dashcrd_txt" id="documentCard" style="cursor: pointer;">
										<h3 class="fs-32 fw-medium mb-2" id="approvedDocs">12</h3>
										<h6 class="fs-16 fw-medium text-dark mb-1">With Documents</h6>
										<span class="fs-12 fw-medium text-success">
											<i class="ti ti-trending-up"></i>8%
											<span class="text-dark">from last month</span>
										</span>
									</div>
								</div>
							</div>
						</div>
						<div class="col-md-3 d-flex">
							<div class="card flex-fill dashboard-card dashboardtop-card" data-show="Empty"
								style="cursor: pointer;">
								<div class="card-body">
									<div class="card_avtr_right">
										<span class="avatar avatar-xxl text-red rounded-4 bg-soft-danger mb-2">
											<i class="ti ti-folder-x fs-40"></i>
										</span>
									</div>
									<div class="dashcrd_txt">
										<h3 class="fs-32 fw-medium mb-2" id="pendingDocs">4</h3>
										<h6 class="fs-16 fw-medium text-dark mb-1">Empty Folders</h6>
										<span class="fs-12 fw-medium text-danger">
											<i class="ti ti-trending-down"></i>2% <span class="text-dark">from last
												month</span>
										</span>
									</div>
								</div>
							</div>
						</div>
						<div class="col-md-3 d-flex">
							<div class="card flex-fill dashboard-card dashboardtop-card" data-show="Shared"
								style="cursor: pointer;">
								<div class="card-body">
									<div class="card_avtr_right">
										<span class="avatar avatar-xxl rounded-4 text-warning bg-soft-warning mb-2">
											<i class="ti ti-users fs-40"></i>
										</span>
									</div>
									<div class="dashcrd_txt">
										<h3 class="fs-32 fw-medium mb-2" id="rejectedDocs">6</h3>
										<h6 class="fs-16 fw-medium text-dark mb-1">Shared Folders</h6>
										<span class="fs-12 fw-medium text-success">
											<i class="ti ti-trending-up"></i> 20% <span class="text-dark">from last
												month</span>
										</span>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="d-flex gap-2 mb-4 justify-content-between align-items-end">
				<div class="filtr_left d-flex gap-4 align-items-center w-50">
					<div class="position-relative w-40 search_folderbar">
						<input type="text" name="q" id="SearchFolderInput" class="form-control"
							placeholder="Search by doc, tag, metadata.." value="">
						<span class="input-icon-addon">
							<i class="ti ti-search"></i>
						</span>
					</div>
					<div class="mb-0">
						<select id="departmentFilter" class="form-select select2" style="width: 200px;">
							<option value="">All Departments</option>
						</select>
					</div>
					<div class="mb-0 position-relative">
						<!-- Filter Button -->
						<button class="btn btn-outline-primary" data-bs-toggle="dropdown">
							<i class="ti ti-filter"></i> Filters
						</button>

						<ul class="dropdown-menu" data-bs-auto-close="outside">
							<!-- VIEW -->
							<li>
								<a class="dropdown-item view-folder" href="#" data-filter="lastView">
									<i class="ti ti-eye"></i> Last View
								</a>
							</li>
							<li>
								<a class="dropdown-item view-folder" href="#" data-filter="lastModified">
									<i class="ti ti-eye"></i> Last Modified
								</a>
							</li>
						</ul>
					</div>
				</div>
				<div class="filtr_right">
					<div class="dropdown w-100 w-sm-auto">
						<div class="input-group">
							<span class="input-group-text border">Sort by:</span>
							<select id="recentActivitySort" class="form-select border text-black">
								<option value="name_asc">A-Z</option>
								<option value="name_desc">Z-A</option>
								<option value="updatedAt_desc">Date (Newest)</option>
								<option value="updatedAt_asc">Date (Oldest)</option>
							</select>
						</div>
					</div>
				</div>
			</div>



			<div id="folder-no-project" class="text-center py-5" style="display:none;">
				<h4 class="text-muted">Please select a project first</h4>
			</div>

			<div id="folder-container"></div>

			<div id="folder-loading" class="text-center py-4" style="display:none;">
				<div class="spinner-border text-primary"></div>
				<p class="mt-2 text-muted">Loading folders...</p>
			</div>

			<div id="folder-empty" class="text-center py-4" style="display:none;">
				<i class="ti ti-folder-off fs-1 text-muted"></i>
				<p class="mt-2 text-muted">No subfolders found</p>
			</div>

		</div>

		<div class="footer mt-4 d-sm-flex align-items-center justify-content-between border-top bg-white p-3">
			<p class="mb-0">2025 &copy; HLFPPT.</p>
			<p>Designed & Developed by <a href="javascript:void(0);" class="text-primary">Duplex services &
					Technology</a></p>
		</div>
	</div>

	<div id="folder-modal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header">
					<h5 id="folder-modal-title" class="modal-title">Create New Folder</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<form id="folderForm">
						<div class="mb-3">
							<label class="form-label">Folder Name</label>
							<input type="text" class="form-control" id="folderName" name="folderName" required
								placeholder="Enter folder name">
						</div>
						<div id="folderMetaFields">
							<div class="mb-3">
								<label for="parentFolder" class="form-label">Parent Folder</label>
								<select id="parentFolder" name="parentFolder" class="form-select select2">
									<option value="">Select Parent Folder</option>
								</select>
							</div>
						
							<div class="mb-3">
								<label for="folderProjectName" class="form-label">Choose Project</label>
								<select id="folderProjectName" class="form-select select2">
									<option value="">Select Project</option>
								</select>
							</div>
						
							<div class="mb-3">
								<label for="folderdepartment" class="form-label">Choose Department</label>
								<select id="folderdepartment" class="form-select select2">
									<option value="">Select Department</option>
								</select>
							</div>
						</div>
						<div class="mb-3 text-center">
							<button class="btn btn-primary rounded-pill" id="folderFormSubmit" type="submit">
								Create Folder
							</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>

	<%- include('../../partials/footer') %>
		<%- include('../../modals/deleteModal') %>
		<script>
			const shareModal = document.getElementById("sharedoc-modal");
			const shareModalEl = document.getElementById("sharedoc-modal");
			const userInviteSelect = document.getElementById("userInviteSelect");
			const accessLevelSelect = document.getElementById("accessLevelSelect");
			const inviteUserBtn = document.getElementById("inviteUserBtn");
			const usersWithAccessContainer = document.getElementById("usersWithAccessContainer");
			const shareLinkInput = document.getElementById("sharelink");
			const copyLinkBtn = document.getElementById("copyLinkBtn");
			const accessTypeSelect = document.getElementById("accessType");
			const roleTypeSelect = document.getElementById("roleType");
			const projectId = "<%= projectId %>";
			const sessionSelectedProjectId = "<%= typeof selectedProjectId !== 'undefined' ? selectedProjectId : '' %>";
			const selectedProjectName = "<%= selectedProjectName %>";
			const isSuperAdmin = window.profile_type === 'superadmin';
			let currentShareFolderId = null;
			let allUsers = [];
			window.profile_type = "<%= profile_type %>";
			const isMobile = window.matchMedia("(max-width: 768px)").matches;
			const folderState = {
				selectedFolders: [],
				currentFolderId: null,
				isLoading: false,
				currentFolderDepartmentId: null,
				currentShow: ''
			};
			document.getElementById('documentCard').addEventListener('click', function () { window.location.href = '/documents/list';});
			let folderTreeCache = { key: null, data: null };
		
			function getFolderCacheKey() {
				return JSON.stringify({
					projectId,
					selectedDepartment,
					searchQuery,
					currentSort,
					currentFilter,
					currentShow: folderState.currentShow
				});
			}
		
			function invalidateFolderCache() {
				folderTreeCache = { key: null, data: null };
			}
		
			function findFolderById(list, id) {
				for (const folder of list) {
					if (folder._id === id) return folder;
					if (folder.children?.length) {
						const found = findFolderById(folder.children, id);
						if (found) return found;
					}
				}
				return null;
			}
		
			const elements = {
				container: document.getElementById('folder-container'),
				loading: document.getElementById('folder-loading'),
				empty: document.getElementById('folder-empty'),
				breadcrumbList: document.getElementById('breadcrumb-list'),
				noProject: document.getElementById('folder-no-project')
			};
		
			let pendingFolderId = null;
			let editingFolderId = null;
		
			// Search and filter state
			let searchQuery = '';
			let selectedDepartment = '';
			let currentSort = 'name_asc';
			let currentFilter = '';
			let searchTimeout = null;
		
			// ============================================
			// STATS CARD CLICK HANDLERS
			// ============================================
			document.querySelectorAll('.dashboard-card[data-show]').forEach(card => {
				card.addEventListener('click', function() {
					const showValue = this.dataset.show;
					
					document.querySelectorAll('.dashboard-card').forEach(c => {
						c.classList.remove('active-stats-card');
					});
					
					this.classList.add('active-stats-card');
					
					folderState.currentShow = showValue;
					folderState.currentFolderId = null;
					folderState.selectedFolders = [];
					invalidateFolderCache();
					loadFolders(null, [], true);
				});
			});
		
			// ============================================
			// SEARCH FUNCTIONALITY
			// ============================================
			document.getElementById('SearchFolderInput')?.addEventListener('input', function () {
				clearTimeout(searchTimeout);
				searchTimeout = setTimeout(() => {
					searchQuery = this.value.trim();
					loadFolders(folderState.currentFolderId, folderState.selectedFolders);
				}, 500);
			});
		
			// ============================================
			// SORT FUNCTIONALITY
			// ============================================
			document.getElementById('recentActivitySort')?.addEventListener('change', function () {
				currentSort = this.value;
				loadFolders(folderState.currentFolderId, folderState.selectedFolders);
			});
		
			// ============================================
			// FILTER FUNCTIONALITY
			// ============================================
			document.querySelectorAll('.view-folder').forEach(link => {
				link.addEventListener('click', function (e) {
					e.preventDefault();
					const filterValue = this.dataset.filter || '';
					currentFilter = filterValue;
		
					document.querySelectorAll('.view-folder').forEach(item => {
						item.classList.remove('active');
					});
					if (filterValue) {
						this.classList.add('active');
					}
		
					loadFolders(folderState.currentFolderId, folderState.selectedFolders);
				});
			});
		
			// ============================================
			// FETCH FOLDER STATISTICS
			// ============================================
			async function fetchFolderStatistics() {
				try {
					const projectId = window.selectedProjectId || '<%= projectId %>';
					const url = projectId
						? `/api/folders-count?projectId=${projectId}`
						: '/api/folders-count';
		
					const response = await fetch(url, {
						credentials: "include",
						cache: "no-store"
					});
		
					if (!response.ok) throw new Error(`HTTP error! ${response.status}`);
		
					const data = await response.json();
					if (!data.success) throw new Error(data.message || "Failed to fetch folder statistics");
		
					return data.data;
				} catch (error) {
					console.error("Error fetching folder statistics:", error);
					return null;
				}
			}
		
			async function updateFolderStatistics() {
				const stats = await fetchFolderStatistics();
				if (!stats) {
					console.warn('Could not load folder statistics');
					return;
				}
		
				const totalDocsEl = document.getElementById('totalDocs');
				const approvedDocsEl = document.getElementById('approvedDocs');
				const pendingDocsEl = document.getElementById('pendingDocs');
				const rejectedDocsEl = document.getElementById('rejectedDocs');
		
				if (totalDocsEl) totalDocsEl.textContent = stats.totalFolders || 0;
				if (approvedDocsEl) approvedDocsEl.textContent = stats.withDocuments || 0;
				if (pendingDocsEl) pendingDocsEl.textContent = stats.emptyFolders || 0;
				if (rejectedDocsEl) rejectedDocsEl.textContent = stats.sharedFolders || 0;
			}
		
			// ============================================
			// FETCH DEPARTMENTS FOR FILTER
			// ============================================
			async function fetchDepartmentsForFilter() {
				try {
					const response = await fetch('/api/departments/search', {
						credentials: "include",
						cache: "no-store"
					});
		
					if (!response.ok) throw new Error(`HTTP error! ${response.status}`);
		
					const data = await response.json();
					if (!data.success) throw new Error(data.message || "Failed to fetch departments");
		
					return data.data || [];
				} catch (error) {
					console.error("Error fetching departments:", error);
					return [];
				}
			}
		
			// ============================================
			// POPULATE DEPARTMENT FILTER DROPDOWN
			// ============================================
			async function populateDepartmentFilter() {
				const select = document.getElementById("departmentFilter");
				if (!select) {
					console.error("Department filter select not found");
					return;
				}
		
				if ($(select).hasClass('select2-hidden-accessible')) {
					$(select).select2('destroy');
				}
		
				select.innerHTML = `<option value="">All Departments</option>`;
		
				try {
					const departments = await fetchDepartmentsForFilter();
					if (departments && departments.length > 0) {
						departments.forEach(dept => {
							select.insertAdjacentHTML(
								"beforeend",
								`<option value="${dept._id}">${dept.name}</option>`
							);
						});
					} else {
						select.insertAdjacentHTML(
							"beforeend",
							`<option value="" disabled>No departments found</option>`
						);
					}
		
					$(select).select2({
						placeholder: "All Departments",
						allowClear: true,
						width: '100%'
					});
		
					if (selectedDepartment) {
						$(select).val(selectedDepartment).trigger('change');
					}
		
					$(select).off('change.deptFilter').on('change.deptFilter', function () {
						selectedDepartment = $(this).val() || '';
						folderState.currentFolderId = null;
						folderState.selectedFolders = [];
						loadFolders(null, []);
					});
		
				} catch (error) {
					console.error("Error populating department filter:", error);
					select.insertAdjacentHTML(
						"beforeend",
						`<option value="" disabled>Error loading departments</option>`
					);
					$(select).select2({
						placeholder: "Error loading departments",
						allowClear: true,
						width: '100%'
					});
				}
			}
		
			// ============================================
			// FETCH FOLDERS WITH ALL PARAMETERS (cached)
			// ============================================
			const fetchFolders = async (forceRefetch = false) => {
				const cacheKey = getFolderCacheKey();
		
				if (!forceRefetch && folderTreeCache.key === cacheKey && folderTreeCache.data) {
					return folderTreeCache.data;
				}
		
				const queryParams = new URLSearchParams();
		
				if (projectId) {
					queryParams.append("projectId", projectId);
				}
		
				if (selectedDepartment && selectedDepartment !== '') {
					queryParams.append("departmentId", selectedDepartment);
				}
				if (searchQuery && searchQuery.trim() !== '') {
					queryParams.append("search", searchQuery.trim());
				}
		
				if (currentSort) {
					queryParams.append("sort", currentSort);
				}
		
				if (currentFilter) {
					queryParams.append("filter", currentFilter);
				}
		
				if (folderState.currentShow !== undefined && folderState.currentShow !== null) {
					queryParams.append("show", folderState.currentShow);
				} else {
					queryParams.append("show", folderState.parentOnly ? "true" : "false");
				}
				if (forceRefetch) {
					queryParams.append("_ts", Date.now());
				}
		
				const url = `/api/folders/tree/structure?${queryParams.toString()}`;
				try {
					const response = await fetch(url, {
						credentials: "include",
						cache: "no-store"
					});
		
					if (!response.ok) throw new Error(`HTTP error! ${response.status}`);
		
					const data = await response.json();
					if (!data.success) throw new Error(data.message || "API request failed");
		
					const tree = data.tree || [];
					folderTreeCache = { key: cacheKey, data: tree };
					return tree;
				} catch (error) {
					console.error('Error fetching folders:', error);
					showToast('Failed to load folders', 'error');
					return [];
				}
			};
		
			// ============================================
			// SET LOADING STATES
			// ============================================
			const setLoadingState = (loading) => {
				elements.loading.style.display = loading ? 'block' : 'none';
				elements.container.style.display = loading ? 'none' : 'flex';
				elements.empty.style.display = 'none';
			};
		
			const setEmptyState = (isEmpty) => {
				elements.empty.style.display = isEmpty ? 'block' : 'none';
				elements.container.style.display = isEmpty ? 'none' : 'flex';
				elements.loading.style.display = 'none';
			};
		
			const showNoProject = (show) => {
				elements.noProject.style.display = show ? 'block' : 'none';
			};
		
			// ============================================
			// GET SUBFOLDERS AND FILES
			// ============================================
			const getSubfolders = (folders, targetFolderId) => {
				const isFilterActive =
					searchQuery || currentSort !== 'name_asc' || currentFilter;
		
				const hasProjectId = projectId && projectId !== '';
		
				if (!targetFolderId) {
					if (selectedDepartment) {
						return folders.map(folder => ({
							...folder,
							children: (folder.children || []).filter(
								child => child.departmentId?._id === selectedDepartment
							),
						}));
					}
		
					const shouldHideRoot =
						(hasProjectId && !isFilterActive) || isFilterActive;
		
					if (shouldHideRoot) {
						return folders.flatMap(folder => folder.children || []);
					}
		
					return folders;
				}
		
				const findFolderAndGetChildren = (list, id) => {
					for (const folder of list) {
						if (folder._id === id) {
							let children = folder.children || [];
		
							if (selectedDepartment) {
								children = children.filter(
									child => child.departmentId?._id === selectedDepartment
								);
							}
		
							return children;
						}
		
						if (folder.children?.length) {
							const result = findFolderAndGetChildren(folder.children, id);
							if (result.length > 0) {
								return result;
							}
						}
					}
		
					return [];
				};
		
				return findFolderAndGetChildren(folders, targetFolderId);
			};
		
			const getCurrentFolderDepartment = async (folderId) => {
				if (!folderId) return null;
		
				try {
					const response = await fetch(`/api/folders/${folderId}`, {
						credentials: "include",
						cache: "no-store"
					});
		
					if (!response.ok) throw new Error(`HTTP error! ${response.status}`);
		
					const data = await response.json();
					if (!data.success) throw new Error(data.message || "No folder details");
		
					return data.departmentId || null;
				} catch (error) {
					console.error("Error fetching folder department:", error);
					return null;
				}
			};
		
			const collectAllFilesRecursively = (allFolders, targetFolderId) => {
				if (!targetFolderId) return [];
		
				const files = [];
		
				const findAndCollectFiles = (list) => {
					for (const folder of list) {
						if (folder._id === targetFolderId) {
							if (folder.files && folder.files.length > 0) {
								files.push(...folder.files);
							}
						}
		
						if (folder.children && folder.children.length > 0) {
							findAndCollectFiles(folder.children);
						}
					}
				};
		
				findAndCollectFiles(allFolders);
				return files;
			};
		
			// ============================================
			// UPDATE BREADCRUMB
			// ============================================
			const rootLabel = selectedProjectName || "Project Folder";
			const updateBreadcrumb = () => {
				const breadcrumbList = elements.breadcrumbList;
				if (!breadcrumbList) return;
		
				breadcrumbList.innerHTML = '';
				let homePath = [...folderState.selectedFolders];
				if (homePath.length > 0) {
					breadcrumbList.innerHTML += `
					<li class="breadcrumb-item">
						<a href="javascript:void(0)" class="breadcrumb-link" data-id=""><i class="ti ti-smart-home"> ${rootLabel} </i></a>
					</li>
				`;
				} else {
					breadcrumbList.innerHTML += `
					<li class="breadcrumb-item active" aria-current="page"><i class="ti ti-smart-home">   ${rootLabel}</i></li>
				`;
				}
		
				let currentPath = [];
				folderState.selectedFolders.forEach((f, index) => {
					currentPath.push(f);
					const isLast = index === folderState.selectedFolders.length - 1;
					const liClass = isLast ? 'breadcrumb-item active' : 'breadcrumb-item';
					const linkContent = isLast
						? f.name
						: `<a href="javascript:void(0)" class="breadcrumb-link" data-id="${f.id}" data-index="${index}">${f.name}</a>`;
		
					breadcrumbList.innerHTML += `
					<li class="${liClass}" ${isLast ? 'aria-current="page"' : ''}>
						${linkContent}
					</li>
				`;
				});
		
				breadcrumbList.querySelectorAll(".breadcrumb-link").forEach(link => {
					link.addEventListener("click", async function () {
						const folderId = this.dataset.id;
						const index = parseInt(this.dataset.index, 10);
		
						let newPath;
		
						if (folderId === "") {
							newPath = [];
						} else {
							newPath = folderState.selectedFolders.slice(0, index + 1);
						}
						await loadFolders(folderId || null, newPath);
					});
				});
			};
		
			// ============================================
			// LOAD FOLDERS
			// ============================================
			const loadFolders = async (parentFolderId = null, parentPath = [], forceRefetch = false) => {
				try {
					showNoProject(false);
		
					const usingCache = !forceRefetch && folderTreeCache.key === getFolderCacheKey() && folderTreeCache.data;
					if (!usingCache) setLoadingState(true);
		
					const allFolders = await fetchFolders(forceRefetch);
					setLoadingState(false);
		
					const subfolders = getSubfolders(allFolders, parentFolderId);
					const allFilesInThisFolderAndSubfolders = collectAllFilesRecursively(allFolders, parentFolderId);
		
					folderState.currentFolderId = parentFolderId;
					folderState.selectedFolders = parentPath;
		
					if (parentFolderId) {
						const currentFolderNode = findFolderById(allFolders, parentFolderId);
						if (currentFolderNode) {
							folderState.currentFolderDepartmentId =
								currentFolderNode.departmentId?._id || currentFolderNode.departmentId || null;
						} else {
							folderState.currentFolderDepartmentId = await getCurrentFolderDepartment(parentFolderId);
						}
					} else {
						folderState.currentFolderDepartmentId = null;
					}
		
					if (!subfolders.length && !allFilesInThisFolderAndSubfolders.length) {
						setEmptyState(true);
						elements.container.innerHTML = "";
						updateBreadcrumb();
						return;
					}
		
					setEmptyState(false);
					elements.container.innerHTML = "";
		
					subfolders.forEach(folder => {
						const div = document.createElement("div");
						div.className = "folderbox shadow-sm";
						div.dataset.id = folder._id;
		
						const isOwner = folder.isOwner;
						const isBlocked = folder.status === "inactive";
						const userPermission = folder.permissions?.[0] || null;
		
						const canView = isSuperAdmin || isOwner ||
							(userPermission && (userPermission.access === "view" || userPermission.access === "edit"));
		
						const canDownload = isSuperAdmin || isOwner ||
							(userPermission && userPermission.canDownload === true);
		
						const isUserBlocked = !isSuperAdmin && !isOwner && isBlocked;
		
						let blockedClass = "";
						if (isBlocked) {
							if (isUserBlocked) blockedClass = "blocked-user";
							else blockedClass = "blocked-owner";
						}
		
						if (blockedClass) div.classList.add(blockedClass);
		
						div.innerHTML = `
						<div class="d-flex gap-3 mb-3">
							<div class="fldricon">
								<img src="/img/icons/folder.png" loading="lazy" decoding="async">
							</div>
							<div class="fldrname">
								<p class="fs-24 fw-bold">${folder.name}</p>
								<span class="badge bg-soft-primary text-primary">${folder.isOwner ? 'Owner' : 'Shared'}</span>
							</div>
						</div>
						
						<div class="foldertxts">
							<p class="mb-2 d-flex align-items-center gap-3">
							<span>
								<i class="ti ti-folder me-1 fs-16 text-warning"></i>
								${folder?.totalFolders ?? 0} Folders
							</span>

							<span>
								<i class="ti ti-files me-1 fs-16 text-primary"></i>
								${folder?.totalDocument ?? 0} Files
							</span>
						</p>
						<p class="mb-2">
							<i class="ti ti-building me-2 fs-16 text-success"></i>
							${folder?.departmentId?.shortName || folder?.departmentId?.name || 'N/A'} Department
						</p>

						<p class="mb-2">
							<i class="ti ti-calendar-time me-2 fs-16 text-muted"></i>
							${
								folder.updatedAt
									? new Date(folder.updatedAt).toLocaleString("en-US", {
										month: "long",
										day: "2-digit",
										year: "numeric",
										hour: "2-digit",
										minute: "2-digit",
										hour12: true
									})
									: "N/A"
							}
						</p>
					</div>
						
						<div class="folder_links">
							<button type="button" class="btn border-0" data-bs-toggle="dropdown">
								<i class="ti ti-dots"></i>
							</button>
							<ul class="dropdown-menu" data-bs-auto-close="outside">
								<li>
									<a class="dropdown-item view-folder 
										${(!canView || isUserBlocked) ? "disabled-link" : ""}"
										href="${(!canView || isUserBlocked) ? "#" : "/" + folder._id + "/list"}">
										<i class="ti ti-eye"></i> View
									</a>
								</li>
								<li>
									<a class="dropdown-item download-folder 
										${(!canDownload || isUserBlocked) ? "disabled-link" : ""}"
										href="#"
										data-folder-id="${folder._id}"
										${(!canDownload || isUserBlocked) ? "style='pointer-events:none;opacity:0.5;'" : ""}
										data-bs-toggle="${(!canDownload || isUserBlocked) ? "" : "modal"}"
										data-bs-target="${(!canDownload || isUserBlocked) ? "" : "#downloaddoc-modal"}">
										<i class="ti ti-download"></i> Download
									</a>
								</li>
								${(isOwner || isSuperAdmin) ? `
									<li><a class="dropdown-item rename-folder" href="#"><i class="ti ti-pencil-minus"></i> Rename</a></li>
									<li>
										<a class="dropdown-item toggle-block" href="#" data-id="${folder._id}">
											<i class="ti ti-lock${isBlocked ? "-open" : ""}"></i>
											<span class="block-text">${isBlocked ? "Unblock" : "Block"}</span>
										</a>
									</li>
									<li><a class="dropdown-item share-btn" href="#" data-doc-id="${folder._id}" data-bs-toggle="modal" data-bs-target="#sharedoc-modal"><i class="ti ti-share"></i> Share</a></li>
									<li><a class="dropdown-item delete-folder" href="#" data-bs-toggle="modal" data-bs-target="#trashdoc-modal"><i class="ti ti-trash"></i> Move to Trash</a></li>
									<li><a class="dropdown-item archive-folder" href="#" data-bs-toggle="modal" data-bs-target="#archivedoc-modal"><i class="ti ti-archive"></i> Move to Archive</a></li>
								` : ""}
							</ul>
						</div>
					`;
		
						if (!isUserBlocked && (canView || isSuperAdmin)) {
							if (isMobile) {
								div.addEventListener("click", () => {
									loadFolders(folder._id, [...parentPath, { id: folder._id, name: folder.name }]);
								});
							} else {
								div.addEventListener("dblclick", () => {
									loadFolders(folder._id, [...parentPath, { id: folder._id, name: folder.name }]);
								});
							}
						}
		
						elements.container.appendChild(div);
					});
		
					allFilesInThisFolderAndSubfolders
						.filter(file => file.status === "active")
						.forEach(file => {
							const ext = file.originalName.split(".").pop().toLowerCase();
							let icon = fileIcons[ext] || fileIcons.default;

							const isImage = ["jpg", "jpeg", "png", "gif", "webp", "bmp", "svg"].includes(ext);
							if (isImage && file.fileUrl) {
								icon = file.fileUrl;
							}

							const fileDiv = document.createElement("div");
							fileDiv.className = "folderbox filebox shadow-sm";
							fileDiv.dataset.id = file._id;

							fileDiv.innerHTML = `
								<div class="d-flex gap-3 mb-3">
									<div class="fldricon me-2">
										<img src="${icon}" alt="File" loading="lazy" decoding="async"
											style="width:40px; height:40px; object-fit:cover; border-radius:4px;">
									</div>
									<div class="file-info" style="flex-direction:column;align-items:start;">
										<p class="mb-1 fw-semibold text-dark" title="${file.originalName}">
											${file.originalName}
										</p>
										<p class="mb-0 badge bg-soft-primary text-primary">
											${(file.size / 1024).toFixed(1)} KB
										</p>
									</div>
								</div>

								<div class="foldertxts">
									<p class="mb-2">
										<strong>Uploaded on:</strong>
										${
											file.updatedAt
												? new Date(file.updatedAt).toLocaleString("en-US", {
													month: "long",
													day: "2-digit",
													year: "numeric",
													hour: "2-digit",
													minute: "2-digit",
													hour12: true
												})
												: "N/A"
										}
									</p>
								</div>

								<div class="folder_links ms-auto">
									<button type="button" class="btn border-0" data-bs-toggle="dropdown">
										<i class="ti ti-dots"></i>
									</button>

									<ul class="dropdown-menu">
										<li>
											<a class="dropdown-item" href="/api/download/file/${file._id}">
												<i class="ti ti-download"></i> Download
											</a>
										</li>

										<li>
											<a class="dropdown-item" href="/folders/view/${file._id}" target="_blank">
												<i class="ti ti-eye"></i> View
											</a>
										</li>
									</ul>
								</div>
							`;
							// Double click anywhere on the card to open the file
							fileDiv.addEventListener("dblclick", (e) => {
								if (e.target.closest(".folder_links")) return;
								window.open(`/folders/view/${file._id}`, "_blank");
							});
							elements.container.appendChild(fileDiv);
						});
		
					updateBreadcrumb();
		
				} catch (err) {
					setLoadingState(false);
					console.error("Error loading folders:", err);
					showToast("No folder details", "error");
				}
			};
		
			// ============================================
			// FOLDER DOWNLOAD HANDLING
			// ============================================
			let pendingFolderName = null;
		
			function getElement(id) {
				const element = document.getElementById(id);
				if (!element) {
					console.error(`Element with id '${id}' not found`);
				}
				return element;
			}
		
			document.addEventListener("click", function (e) {
				const item = e.target.closest("a.dropdown-item");
				if (!item) return;
		
				if (item.textContent.includes("Download")) {
					const folderBox = item.closest(".folderbox");
					if (!folderBox) {
						showToast("Could not find folder", "error");
						return;
					}
		
					const folderId = folderBox.dataset.id;
					const folderName = folderBox.querySelector(".fldrname p")?.textContent || "Folder";
		
					if (!folderId) {
						showToast("No folder ID found", "error");
						return;
					}
					pendingFolderId = folderId;
					pendingFolderName = folderName;
		
					const modalTitle = getElement("downloadModalTitle");
					const fileLabel = getElement("downloadFileLabel");
					const fileSize = getElement("downloadFileSize");
		
					if (modalTitle) modalTitle.textContent = `Download "${folderName}"`;
					if (fileLabel) fileLabel.textContent = `Folder: ${folderName}`;
					if (fileSize) fileSize.textContent = "Click Download to start";
		
					const modalElement = getElement("downloaddoc-modal");
					if (modalElement) {
						const modal = new bootstrap.Modal(modalElement);
						modal.show();
					} else {
						showToast("Download modal not found", "error");
					}
				}
			});
		
			const confirmDownloadBtn = getElement("confirmDownload");
			if (confirmDownloadBtn) {
				confirmDownloadBtn.addEventListener("click", async function () {
					if (!pendingFolderId || !pendingFolderName) {
						showToast("No folder selected to download", "error");
						return;
					}
		
					const folderNameForToast = pendingFolderName;
					const modalElement = getElement("downloaddoc-modal");
					if (modalElement) {
						const modal = bootstrap.Modal.getInstance(modalElement);
						if (modal) modal.hide();
					}
		
					showToast(`Preparing download: ${pendingFolderName}`, "info");
		
					try {
						const downloadUrl = `/api/download/folder/${pendingFolderId}?t=${Date.now()}`;
						const iframe = document.createElement('iframe');
						iframe.style.display = 'none';
						iframe.src = downloadUrl;
						document.body.appendChild(iframe);
		
						setTimeout(() => {
							const link = document.createElement('a');
							link.href = downloadUrl;
							link.setAttribute('download', `${pendingFolderName}.zip`);
							document.body.appendChild(link);
							link.click();
							document.body.removeChild(link);
						}, 100);
		
						setTimeout(() => {
							showToast(`Download started: ${folderNameForToast}.zip`, "success");
						}, 1000);
						setTimeout(() => {
							if (iframe.parentNode) {
								iframe.parentNode.removeChild(iframe);
							}
						}, 10000);
		
					} catch (error) {
						console.error("Download failed:", error);
						showToast(`Download failed: ${error.message}`, "error");
					} finally {
						pendingFolderId = null;
						pendingFolderName = null;
					}
				});
			}
		
			// ============================================
			// FOLDER CLICK HANDLERS
			// ============================================
			elements.container.addEventListener("click", (e) => {
				const link = e.target.closest("a");
				const downloadBtn = e.target.closest(".download-folder");
				if (!link) return;
		
				const folderBox = link.closest(".folderbox");
				if (!folderBox) return;
		
				const id = folderBox.dataset.id;
				if (link.classList.contains("rename-folder")) {
					editingFolderId = id;
		
					document.getElementById("folderName").value =
						folderBox.querySelector(".fldrname p").textContent;
		
					document.getElementById("folder-modal-title").textContent = "Rename Folder";
					document.getElementById("folderFormSubmit").textContent = "Save";
		
					document.getElementById("folderMetaFields").style.display = "none";
		
					new bootstrap.Modal("#folder-modal").show();
				}
		
				if (link.classList.contains("delete-folder")) pendingFolderId = id;
				if (link.classList.contains("archive-folder")) pendingFolderId = id;
		
				if (downloadBtn) {
					const folderId = folderBox.dataset.id;
		
					Swal.fire({
						title: "Preparing your download...",
						text: "Please wait while we compress the folder.",
						allowOutsideClick: false,
						didOpen: () => Swal.showLoading()
					});
		
					const tempLink = document.createElement("a");
					tempLink.href = `/api/folders/download/${folderId}`;
					tempLink.setAttribute("download", "");
					document.body.appendChild(tempLink);
					tempLink.click();
					tempLink.remove();
					setTimeout(() => Swal.close(), 1800);
				}
			});
		
			// ============================================
			// FOLDER FORM SUBMIT
			// ============================================
			document.getElementById("folderForm")?.addEventListener("submit", async (e) => {
				e.preventDefault();
		
				const name = document.getElementById("folderName").value.trim();
				const parentId = document.getElementById("parentFolder").value;
				const projectIdFromSelect = document.getElementById("folderProjectName").value;
				const departmentIdFromSelect = document.getElementById("folderdepartment").value;
		
				if (!name) {
					showToast("Folder name is required", "error");
					return;
				}
		
				try {
					const url = editingFolderId ? `/api/folders/${editingFolderId}/rename` : `/api/folders`;
					const method = editingFolderId ? "PATCH" : "POST";
		
					const body = {
						name: name,
						projectId: projectIdFromSelect || projectId || null,
						parentId: parentId || null,
						departmentId: departmentIdFromSelect || null
					};
		
					const res = await fetch(url, {
						method,
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify(body)
					});
		
					const data = await res.json();
		
					if (!data.success) throw new Error(data.message || "Failed to save folder");
		
					showToast(editingFolderId ? "Folder renamed successfully" : "Folder created successfully", "success");
		
					const modalEl = document.getElementById("folder-modal");
					const modalInstance = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
					modalInstance.hide();
		
					editingFolderId = null;
					loadFolders(folderState.currentFolderId, folderState.selectedFolders, true);
		
				} catch (err) {
					console.error(err);
					showToast(err.message || "Error saving folder", "error");
				}
			});
		
			// ============================================
			// TRASH FOLDER
			// ============================================
			document.getElementById("confirm-trash-folder")?.addEventListener("click", async () => {
				if (!pendingFolderId) return;
		
				const trashModalEl = document.getElementById("trashdoc-modal");
				const trashModal = bootstrap.Modal.getInstance(trashModalEl);
		
				try {
					if (trashModal) trashModal.hide();
					showToast("Moving folder to Trash...", "info");
					const res = await fetch(`/api/folderstatus/${pendingFolderId}`, {
						method: "PATCH",
						headers: { "Content-Type": "application/json" }
					});
					let data = {};
					try {
						data = await res.json();
					} catch (err) {
						console.warn("No JSON in response or parse failed:", err);
					}
		
					if (!res.ok || !data.success) {
						console.error("Failed to move to trash:", res.status, data);
						showToast(data.message || "Failed to move to Recyclebin", "success");
						pendingFolderId = null;
						return;
					}
					try {
						const el = elements.container.querySelector(`.folderbox[data-id="${pendingFolderId}"]`);
						if (el) el.remove();
					} catch (err) {
						console.warn("Could not remove folder element from DOM:", err);
					}
		
					showToast(data.message || "Folder successfully moved", "success");
		
					setLoadingState(true);
					try {
						await loadFolders(folderState.currentFolderId, folderState.selectedFolders, true);
					} catch (err) {
						console.error("Error while reloading folders after trashing:", err);
						showToast("Folder moved but failed to refresh view", "warning");
					} finally {
						setLoadingState(false);
					}
		
				} catch (err) {
					console.error("Error moving folder to trash:", err);
					showToast("Failed to move folder", "error");
				} finally {
					pendingFolderId = null;
					const backdrop = document.querySelector('.modal-backdrop');
					if (backdrop) backdrop.remove();
					document.body.classList.remove('modal-open');
				}
			});
		
			// ============================================
			// SHARE LINK GENERATION - UPDATED
			// ============================================
			async function generateShareLink(folderId, accessType = "viewer", roleType = "viewer") {
				if (!folderId) {
					console.warn("No folder ID provided to generateShareLink");
					return null;
				}
		
				try {
					const res = await fetch(`/api/folders/${folderId}/link`, {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ 
							access: "viewer",
							role: roleType
						})
					});
		
					const data = await res.json();
					
					if (!res.ok) {
						throw new Error(data.message || "Failed to generate share link");
					}
					
					if (data.link) {
						if (shareLinkInput) {
							shareLinkInput.value = data.link;
							shareLinkInput.classList.remove('generating');
						}
						window.currentShareLink = data.link;
						return data.link;
					} else {
						throw new Error("No link returned from server");
					}
		
				} catch (err) {
					console.error("Error generating share link:", err);
					if (shareLinkInput) {
						shareLinkInput.value = "Failed to generate link";
						shareLinkInput.classList.add('generating');
					}
					window.currentShareLink = null;
					showToast("Failed to generate share link: " + err.message, 'error');
					return null;
				}
			}
		
			// ============================================
			// BLOCK/UNBLOCK HANDLING
			// ============================================
			elements.container.addEventListener("click", async (e) => {
				const blockBtn = e.target.closest(".toggle-block");
				if (!blockBtn) return;
		
				const folderId = blockBtn.dataset.id;
				if (!folderId) return;
		
				const textSpan = blockBtn.querySelector(".block-text");
				const icon = blockBtn.querySelector("i");
				if (!textSpan || !icon) return;
		
				const newStatus = textSpan.textContent.trim().toLowerCase() === "block" ? "inactive" : "active";
		
				try {
					const res = await fetch(`/api/update/folders/${folderId}/permissions`, {
						method: "PATCH",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ status: newStatus })
					});
		
					const data = await res.json();
					if (!res.ok) throw new Error(data.error || "Failed to update folder status");
					icon.className = `ti ti-lock${newStatus === "inactive" ? '-open' : ''}`;
					textSpan.textContent = newStatus === "inactive" ? "Unblock" : "Block";
		
					invalidateFolderCache();
		
					showToast(`Folder ${newStatus === "inactive" ? "blocked" : "unblocked"} successfully`, 'success');
		
				} catch (err) {
					console.error(err);
					showToast("Failed to update folder status", 'error');
				}
			});
		
			// ============================================
			// FOLDER SHARE MODAL
			// ============================================
			elements.container.addEventListener("click", async (e) => {
				const shareBtn = e.target.closest(".share-btn");
				if (!shareBtn) return;
		
				currentShareFolderId = shareBtn.dataset.docId;
				if (!currentShareFolderId) return;
		
				try {
					await loadFolderShares(currentShareFolderId);
					updateAccessInfoText();
					new bootstrap.Modal(shareModalEl).show();
				} catch (err) {
					console.error("Failed to load share info:", err);
				}
			});
		
			shareModalEl.addEventListener("hidden.bs.modal", () => {
				currentShareFolderId = null;
				usersWithAccessContainer.innerHTML = "";
				if (shareLinkInput) shareLinkInput.value = "";
				window.currentShareLink = null;
				if (accessTypeSelect) accessTypeSelect.value = "anyone";
				if (roleTypeSelect) roleTypeSelect.value = "viewer";
				updateAccessInfoText();
				if (userInviteSelect) userInviteSelect.value = "";
			});
		
			// ============================================
			// SHARE MODAL SHOW EVENT - Generate link when modal opens
			// ============================================
			shareModalEl.addEventListener("show.bs.modal", async function () {
				if (currentShareFolderId) {
					const accessType = accessTypeSelect ? accessTypeSelect.value : "anyone";
					const roleType = roleTypeSelect ? roleTypeSelect.value : "viewer";
					
					if (shareLinkInput) {
						shareLinkInput.value = "Generating link...";
						shareLinkInput.classList.add('generating');
					}
					
					await generateShareLink(currentShareFolderId, accessType, roleType);
				}
			});
		
			function updateAccessInfoText() {
				const infoText = document.getElementById("infoText");
				if (!infoText) return;
		
				const accessType = accessTypeSelect ? accessTypeSelect.value : "anyone";
				const roleType = roleTypeSelect ? roleTypeSelect.value : "viewer";
		
				if (accessType === "anyone") {
					infoText.textContent = roleType === "viewer" ?
						"Anyone on the internet with the link can view" :
						"Anyone on the internet with the link can edit";
					if (roleTypeSelect) roleTypeSelect.style.display = "";
				} else {
					infoText.textContent = "Only people with access can view";
					if (roleTypeSelect) roleTypeSelect.style.display = "none";
				}
			}
		
			async function loadFolderShares(folderId) {
				try {
					const res = await fetch(`/api/folders/${folderId}`);
					const data = await res.json();
					usersWithAccessContainer.innerHTML = "";
		
					(data.usersWithAccess || []).forEach(user => {
						const div = document.createElement("div");
						div.className = "user-accssrow d-flex justify-content-between align-items-center mb-2";
						div.innerHTML = `
						<div class="empname_eml">
							<div class="fw-normal fs-18">${user.name}</div>
							<small class="fs-16">${user.email}</small>
						</div>
						<div class="d-flex align-items-center gap-4">
							<div class="form-check form-switch">
								<label>Download Access</label>
								<input class="form-check-input download-access" type="checkbox" ${user.canDownload ? 'checked' : ''} data-user-id="${user.id}">
							</div>
							<select class="form-select form-select-sm border-0" style="width:100px;" data-user-id="${user.id}">
								<option value="edit" ${user.access.includes('edit') ? 'selected' : ''}>Edit</option>
								<option value="view" ${user.access.includes('view') ? 'selected' : ''}>View</option>
							</select>
							<button class="btn btn-sm remvaccessbtn remove-access" data-user-id="${user.id}">Remove</button>
						</div>
					`;
						usersWithAccessContainer.appendChild(div);
					});
					
					if ((data.shareLinks || []).length > 0) {
						const shareData = data.shareLinks[0];
						const role = shareData.role || "viewer";
						const access = shareData.accessType || "anyone";
						
						if (accessTypeSelect) accessTypeSelect.value = access;
						if (roleTypeSelect) roleTypeSelect.value = role;
						updateAccessInfoText();
		
						const shareLink = `${window.location.origin}/folders/${shareData.access}/${folderId}?token=${shareData.token}`;
						if (shareLinkInput) {
							shareLinkInput.value = shareLink;
							shareLinkInput.classList.remove('generating');
						}
						window.currentShareLink = shareLink;
					} else {
						if (accessTypeSelect) accessTypeSelect.value = "anyone";
						if (roleTypeSelect) roleTypeSelect.value = "viewer";
						updateAccessInfoText();
						await generateShareLink(folderId, "anyone", "viewer");
					}
		
				} catch (err) {
					console.error("Error loading folder shares:", err);
					showToast("Failed to load share information", 'error');
				}
			}
		
			// ============================================
			// INVITE USER
			// ============================================
			inviteUserBtn.addEventListener("click", async () => {
				const userId = userInviteSelect.value;
				const access = accessLevelSelect.value;
		
				if (!currentShareFolderId || !userId)
					return showToast("Select a user to invite", 'warning');
		
				inviteUserBtn.disabled = true;
				const existingUser = usersWithAccessContainer.querySelector(`.download-access[data-user-id="${userId}"]`);
				if (existingUser) {
					showToast("User is already invited", 'info');
					inviteUserBtn.disabled = false;
					return;
				}
		
				let customStart = null;
				let customEnd = null;
				const durationRadio = document.querySelector('input[name="time"]:checked');
				let duration = durationRadio ? durationRadio.id : "lifetime";
				let expiresAt = null;
		
				const now = new Date();
		
				switch (duration) {
					case "oneday":
						expiresAt = new Date(now.getTime() + 1 * 24 * 60 * 60 * 1000);
						break;
					case "oneweek":
						expiresAt = new Date(now.getTime() + 7 * 24 * 60 * 60 * 1000);
						break;
					case "onemonth":
						expiresAt = new Date(now.getTime() + 30 * 24 * 60 * 60 * 1000);
						break;
					case "custom":
						const customRange = document.getElementById("flatpickr-range").value.trim();
						if (!customRange.includes(" to ")) {
							showToast("Please select a valid custom date range.", 'warning');
							inviteUserBtn.disabled = false;
							return;
						}
		
						const [startRaw, endRaw] = customRange.split(" to ");
						const [d1, m1, y1] = startRaw.trim().split("-");
						const [d2, m2, y2] = endRaw.trim().split("-");
		
						const startDate = new Date(`${y1}-${m1}-${d1}T00:00:00.000Z`);
						const endDate = new Date(`${y2}-${m2}-${d2}T23:59:59.999Z`);
		
						if (isNaN(startDate.getTime()) || isNaN(endDate.getTime())) {
							showToast("Invalid date selection. Please reselect range.", 'warning');
							inviteUserBtn.disabled = false;
							return;
						}
		
						customStart = startDate.toISOString();
						customEnd = endDate.toISOString();
						expiresAt = customEnd;
						break;
					case "onetime":
						expiresAt = new Date(now.getTime() + 1 * 60 * 60 * 1000);
						break;
					case "lifetime":
					default:
						expiresAt = null;
				}
		
				try {
					const res = await fetch(`/api/folders/${currentShareFolderId}/share`, {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({
							userId,
							access,
							shareLink: window.currentShareLink,
							duration,
							expiresAt,
							customStart,
							customEnd
						})
					});
		
					const data = await res.json();
					if (!res.ok) throw new Error(data.error || "Failed to share folder");
		
					await loadFolderShares(currentShareFolderId);
					userInviteSelect.value = "";
					showToast("User invited successfully", 'success');
		
				} catch (err) {
					console.error(err);
					showToast("Failed to invite user", 'error');
				} finally {
					inviteUserBtn.disabled = false;
				}
			});
		
			let userToRemove = null;
		
			usersWithAccessContainer.addEventListener("click", (e) => {
				if (!e.target.classList.contains("remove-access")) return;
		
				userToRemove = e.target.dataset.userId;
				if (!userToRemove || !currentShareFolderId) return;
		
				new bootstrap.Modal(document.getElementById("confirmDeleteModal")).show();
			});
		
			// ============================================
			// SHARE BUTTON - Update Permissions
			// ============================================
			document.getElementById("shareBtn").addEventListener("click", async () => {
				if (!currentShareFolderId) return;
		
				const permissionData = [];
		
				usersWithAccessContainer.querySelectorAll(".user-accssrow").forEach(row => {
					const userId = row.querySelector(".download-access").dataset.userId;
					const canDownload = row.querySelector(".download-access").checked;
					const access = "view";
		
					permissionData.push({
						principalId: userId,
						canDownload,
						access
					});
				});
		
				try {
					const res = await fetch(`/api/update/folders/${currentShareFolderId}/permissions`, {
						method: "PATCH",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ permissions: permissionData })
					});
		
					const data = await res.json();
					if (!res.ok) throw new Error(data.message || "Bulk update failed");
		
					showToast("Permissions updated successfully", "success");
					bootstrap.Modal.getInstance(shareModalEl).hide();
		
				} catch (err) {
					console.error(err);
					showToast("Failed to update permissions", "error");
				}
			});
		
			// ============================================
			// ACCESS TYPE CHANGE HANDLER
			// ============================================
			if (accessTypeSelect) {
				accessTypeSelect.addEventListener("change", async () => {
					updateAccessInfoText();
		
					if (currentShareFolderId) {
						const accessType = accessTypeSelect.value;
						const roleType = roleTypeSelect ? roleTypeSelect.value : "viewer";
						
						if (accessType === "anyone") {
							if (shareLinkInput) {
								shareLinkInput.value = "Generating link...";
								shareLinkInput.classList.add('generating');
							}
							await generateShareLink(currentShareFolderId, accessType, roleType);
						} else {
							if (shareLinkInput) {
								shareLinkInput.value = "Link only for invited users";
								shareLinkInput.classList.add('generating');
							}
							window.currentShareLink = null;
						}
					} else {
						if (shareLinkInput) shareLinkInput.value = "";
						window.currentShareLink = null;
					}
				});
			}
		
			// ============================================
			// ROLE TYPE CHANGE HANDLER
			// ============================================
			if (roleTypeSelect) {
				roleTypeSelect.addEventListener("change", async () => {
					updateAccessInfoText();
					
					if (currentShareFolderId && accessTypeSelect && accessTypeSelect.value === "anyone") {
						const accessType = accessTypeSelect.value;
						const roleType = roleTypeSelect.value;
						
						if (shareLinkInput) {
							shareLinkInput.value = "Generating link...";
							shareLinkInput.classList.add('generating');
						}
						
						await generateShareLink(currentShareFolderId, accessType, roleType);
						showToast("Link updated with new role", 'success');
					}
				});
			}
		
			// ============================================
			// COPY SHARE LINK
			// ============================================
			if (copyLinkBtn) {
				copyLinkBtn.addEventListener("click", () => {
					if (shareLinkInput && shareLinkInput.value && 
						shareLinkInput.value !== "No link" && 
						shareLinkInput.value !== "Generating link..." && 
						shareLinkInput.value !== "Failed to generate link" &&
						shareLinkInput.value !== "Link only for invited users") {
						shareLinkInput.select();
						try {
							document.execCommand("copy");
							showToast("Link copied to clipboard", 'success');
						} catch (err) {
							navigator.clipboard.writeText(shareLinkInput.value)
								.then(() => showToast("Link copied to clipboard", 'success'))
								.catch(() => showToast("Failed to copy link", 'error'));
						}
					} else {
						showToast("No valid link to copy", 'warning');
					}
				});
			}
		
			// ============================================
			// FETCH PROJECTS AND DEPARTMENTS
			// ============================================
			async function fetchProjects() {
				try {
					const response = await fetch('/api/projects', {
						credentials: "include",
						cache: "no-store"
					});
		
					if (!response.ok) throw new Error(`HTTP error! ${response.status}`);
		
					const data = await response.json();
					if (!data.success) throw new Error(data.message || "Failed to fetch projects");
		
					return data.data || [];
				} catch (error) {
					console.error("Error fetching projects:", error);
					showToast("Failed to load projects", "error");
					return [];
				}
			}
		
			async function fetchDepartments() {
				try {
					const response = await fetch('/api/departments/search', {
						credentials: "include",
						cache: "no-store"
					});
		
					if (!response.ok) throw new Error(`HTTP error! ${response.status}`);
		
					const data = await response.json();
					if (!data.success) throw new Error(data.message || "Failed to fetch departments");
		
					return data.data || [];
				} catch (error) {
					console.error("Error fetching departments:", error);
					showToast("Failed to load departments", "error");
					return [];
				}
			}
		
			async function populateProjectDropdown() {
				const select = document.getElementById("folderProjectName");
				if (!select) return;
		
				if ($(select).hasClass('select2-hidden-accessible')) {
					$(select).select2('destroy');
				}
		
				select.innerHTML = `<option value="">Select Project</option>`;
		
				const projects = await fetchProjects();
		
				projects.forEach(project => {
					const isSelected = (project._id === (projectId || window.selectedProjectId));
					select.insertAdjacentHTML(
						"beforeend",
						`<option value="${project._id}" ${isSelected ? 'selected' : ''}>
						${project.projectName}
					</option>`
					);
				});
		
				$(select).select2({
					placeholder: "Select Project",
					allowClear: true,
					width: '100%'
				});
		
				const currentProject = projectId || window.selectedProjectId;
				if (currentProject) {
					$(select).val(currentProject).trigger('change');
				}
			}
		
			async function populateDepartmentDropdown(preSelectedDepartmentId = null) {
				const select = document.getElementById("folderdepartment");
				if (!select) return;
		
				if ($(select).hasClass('select2-hidden-accessible')) {
					$(select).select2('destroy');
				}
		
				select.innerHTML = `<option value="">Select Department</option>`;
		
				const departments = await fetchDepartments();
		
				departments.forEach(dept => {
					const isSelected = (preSelectedDepartmentId && dept._id === preSelectedDepartmentId);
					select.insertAdjacentHTML(
						"beforeend",
						`<option value="${dept._id}" ${isSelected ? 'selected' : ''}>
						${dept.name}
					</option>`
					);
				});
		
				$(select).select2({
					placeholder: "Select Department",
					allowClear: true,
					width: '100%'
				});
		
				if (preSelectedDepartmentId) {
					$(select).val(preSelectedDepartmentId).trigger('change');
				}
			}
		
			async function populateParentFolders() {
				const select = document.getElementById("parentFolder");
				if (!select) return;
		
				if ($(select).hasClass('select2-hidden-accessible')) {
					$(select).select2('destroy');
				}
		
				select.innerHTML = `<option value="">Select Parent Folder</option>`;
		
				try {
					const projectSelect = document.getElementById("folderProjectName");
					const currentProjectId = projectSelect ? projectSelect.value : projectId;
		
					if (!currentProjectId) {
						select.insertAdjacentHTML("beforeend", `<option disabled>Select a project first</option>`);
						$(select).select2({
							placeholder: "Select Parent Folder",
							allowClear: true,
							width: '100%'
						});
						return;
					}
		
					const res = await fetch(`/api/folders/tree/structure?projectId=${currentProjectId}`, {
						credentials: "include",
						cache: "no-store"
					});
		
					const data = await res.json();
		
					if (!data.success || !Array.isArray(data.tree)) {
						throw new Error(data.message || "Failed to fetch folder tree");
					}
		
					const buildFolderOptions = (folders, parentPath = '', isRoot = false) => {
						folders.forEach(folder => {
							const fullPath = isRoot
								? ''
								: (parentPath ? `${parentPath}/${folder.name}` : folder.name);
		
							if (!isRoot) {
								select.insertAdjacentHTML(
									"beforeend",
									`<option value="${folder._id}">${fullPath}</option>`
								);
							}
		
							if (folder.children?.length) {
								buildFolderOptions(
									folder.children,
									isRoot ? '' : fullPath,
									false
								);
							}
						});
					};
		
					buildFolderOptions(data.tree);
		
					if (folderState.currentFolderId) {
						select.value = folderState.currentFolderId;
					}
		
					$(select).select2({
						placeholder: "Select Parent Folder",
						allowClear: true,
						width: '100%'
					});
		
				} catch (err) {
					console.error("Error loading parent folders:", err);
					select.insertAdjacentHTML("beforeend", `<option disabled>Error loading folders</option>`);
					$(select).select2({
						placeholder: "Error loading folders",
						allowClear: true,
						width: '100%'
					});
				}
			}
		
			$(document).on('change', '#folderProjectName', function() {
				populateParentFolders();
			});
		
			// ============================================
			// CONFIRM DELETE AND ARCHIVE
			// ============================================
			document.getElementById("confirmDeleteBtn").addEventListener("click", async () => {
				if (!userToRemove || !currentShareFolderId) return;
		
				try {
					const res = await fetch(`/api/folders/${currentShareFolderId}/unshare`, {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ userId: userToRemove })
					});
		
					const data = await res.json();
					if (!res.ok) throw new Error(data.error || "Failed to remove access");
		
					await loadFolderShares(currentShareFolderId);
					showToast("User access removed successfully", 'success');
		
				} catch (err) {
					console.error(err);
					showToast("Failed to remove access", 'error');
				} finally {
					bootstrap.Modal.getInstance(document.getElementById("confirmDeleteModal")).hide();
					userToRemove = null;
				}
			});
		
			document.getElementById("confirm-archive-folder")?.addEventListener("click", async () => {
				if (!pendingFolderId) return;
				try {
					const res = await fetch(`/api/folders/${pendingFolderId}/archive`, { method: "PATCH" });
					const data = await res.json();
		
					if (!data.success) {
						showToast(data.message || "Failed to move to Archive", "warning");
						return;
					}
		
					showToast(data.message || "Folder successfully archived", "success");
					await loadFolders(folderState.currentFolderId, folderState.selectedFolders, true);
		
				} catch (err) {
					console.error(err);
					showToast("Failed to archive folder", "error");
				} finally {
					pendingFolderId = null;
					const modal = bootstrap.Modal.getInstance(document.getElementById("archivedoc-modal"));
					if (modal) modal.hide();
				}
			});
		
			// ============================================
			// ADD FOLDER BUTTON
			// ============================================
			document.getElementById("btnAddFolder")?.addEventListener("click", async () => {
				editingFolderId = null;
		
				document.getElementById("folderForm").reset();
				document.getElementById("folder-modal-title").textContent = "Create New Folder";
				document.getElementById("folderFormSubmit").textContent = "Create Folder";
		
				document.getElementById("folderMetaFields").style.display = "block";
		
				await populateProjectDropdown();
				
				let preSelectedDept = null;
				
				if (selectedDepartment && selectedDepartment !== '') {
					preSelectedDept = selectedDepartment;
					console.log('Using department from filter:', preSelectedDept);
				} else if (folderState.currentFolderDepartmentId) {
					preSelectedDept = folderState.currentFolderDepartmentId;
					console.log('Using department from current folder:', preSelectedDept);
				} else {
					console.log('No department to pre-select');
				}
				
				await populateDepartmentDropdown(preSelectedDept);
				await populateParentFolders();
		
				new bootstrap.Modal("#folder-modal").show();
			});
		
			// ============================================
			// DOM CONTENT LOADED
			// ============================================
			document.addEventListener("DOMContentLoaded", () => {
				populateDepartmentFilter();
				updateFolderStatistics();
				loadFolders();
			});
		</script>