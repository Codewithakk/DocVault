<%- include('../../partials/header') %>

<div class="page-wrapper">
    <div class="content">
        <div class="d-flex align-items-center justify-content-between page-breadcrumb mb-3">
            <div class="my-auto mb-2">
                <h2 class="mb-1">
                    <%= user.name %>
                </h2>
                <nav>
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#"><i class="ti ti-smart-home"></i></a></li>
                        <li class="breadcrumb-item">User List</li>
                        <li class="breadcrumb-item active">
                            <%= user.name %>
                        </li>
                    </ol>
                </nav>
            </div>

            <% if (!viewOnly) { %>
                <div class="rtbtn">
                    <button id="toggleModeBtn" class="btn btn-secondary btn-lg rounded-pill me-2 mb-2">
                        <i class="ti ti-eye me-1"></i> View
                    </button>
                </div>
            <% } %>
        </div>

        <div id="viewMode" class="user-details" style="<%= viewOnly ? '' : 'display:none;' %>">
            <%- include('../../forms/user-form', { 
                user, 
                departments, 
                designations, 
                countries,
                states,
                cities,
                viewOnly: true 
            }) %>
        </div>

        <div id="editMode" class="user-details" style="<%= viewOnly ? 'display:none;' : '' %>">
            <form id="editUserForm" novalidate>
                <%- include('../../forms/user-form', { 
                    user, 
                    departments, 
                    designations, 
                    countries,
                    states,
                    cities,
                    viewOnly: false 
                }) %>
            </form>
        </div>

        <div id="userData" data-user-id="<%= user._id %>"></div>
    </div>

    <footer class="footer mt-4 d-sm-flex align-items-center justify-content-between border-top bg-white p-3">
        <p class="mb-0">2025 &copy; HLFPPT.</p>
        <p>Designed & Developed by <a href="#" class="text-primary">Duplex Services & Technology</a></p>
    </footer>
</div>

<script>
    $(document).ready(function () {
        // Initialize Select2 for all dropdowns
        $('#department, #designation, #country, #state, #city').select2({
            placeholder: '-- Select --',
            allowClear: true
        });
    
        $('#toggleModeBtn').click(function () {
            $('#viewMode').toggle();
            $('#editMode').toggle();
            $(this).toggleClass('btn-secondary btn-primary');
            $(this).html($(this).hasClass('btn-primary') ? '<i class="ti ti-pencil me-1"></i> Edit' : '<i class="ti ti-eye me-1"></i> View');
        });
    
        $('#editUserForm').on('submit', function (e) {
            e.preventDefault();
            const userId = $('#userData').data('user-id');
    
            // Create FormData for file upload
            const formData = new FormData();
            formData.append('name', $('#editUserForm #name').val());
            formData.append('phone_number', $('#editUserForm #phone_number').val());
            formData.append('employee_id', $('#editUserForm #employee_id').val());
            formData.append('department', $('#editUserForm #department').val());
            formData.append('designation_id', $('#editUserForm #designation_id').val());
            formData.append('country', $('#editUserForm #country').val());
            formData.append('state', $('#editUserForm #state').val());
            formData.append('city', $('#editUserForm #city').val());
            formData.append('post_code', $('#editUserForm #post_code').val());
            formData.append('address', $('#editUserForm #address').val());
            formData.append('status', $('#editUserForm #status').val());
            
            // Append file if selected
            const fileInput = document.getElementById('fileInput');
            if (fileInput && fileInput.files.length > 0) {
                formData.append('profile_image', fileInput.files[0]);
            }
    
            $.ajax({
                url: `${baseUrl}/api/user/${userId}`,
                method: 'PUT',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    if (res.success) {
                        showToast('User updated successfully!', 'success');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showToast(res.message || 'Update failed', 'error');
                    }
                },
                error: function (err) {
                    showToast('Error updating user', 'error');
                }
            });
        });
    
        // File upload handler
        const uploadBox = document.getElementById("uploadprofileBox");
        if (uploadBox) {
            uploadBox.addEventListener("click", () => {
                document.getElementById("fileInput").click();
            });
        }
    
        const fileInput = document.getElementById("fileInput");
        if (fileInput) {
            fileInput.addEventListener("change", (e) => {
                const preview = document.getElementById("preview");
                if (preview) {
                    preview.innerHTML = "";
                    const file = e.target.files[0];
                    if (file) {
                        const img = document.createElement("img");
                        img.src = URL.createObjectURL(file);
                        img.style.maxWidth = "100px";
                        img.classList.add("img-thumbnail");
                        preview.appendChild(img);
                    }
                }
            });
        }
    });
</script>

<%- include('../../partials/footer') %>